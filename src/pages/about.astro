---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Band from '../components/Band.astro';
import { bodyToHtml } from '../lib/plainText';

const aboutEntry = await getEntry('site', 'about');
const about = aboutEntry!.data;
const bodyHtml = bodyToHtml(about.body ?? '');
---

<BaseLayout
  title="About"
  description="About Isaiah Ho — business student at Singapore Management University, building toward strategy and management consulting."
>
  <Band variant="ink" eyebrow="About">
    <h1>About</h1>
    <div class:list={["about-layout", { "about-layout--text-only": !about.image }]}>
      <div class="prose" set:html={bodyHtml} />
      {about.image && (
        <div class="about-portrait">
          <img src={about.image} alt="Isaiah Ho" />
        </div>
      )}
    </div>
  </Band>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin: 0 0 2rem;
  }

  .about-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(200px, 300px);
    gap: 3rem;
    align-items: start;
  }
  .about-layout--text-only {
    grid-template-columns: 1fr;
  }
  .prose { order: 1; max-width: 65ch; }
  .about-portrait { order: 2; }

  .about-portrait img {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 32rem;
    border-radius: 4px;
    border: 1px solid var(--line);
    display: block;
    margin: 0 auto;
  }

  /* First paragraph keeps the existing "lede" treatment (larger, muted) purely
     via :global(:first-of-type) — the schema no longer has a separate lede
     field (tech-lead Decision C merged lede+paragraphs into one `body`), but
     the visual rhythm the site already had is preserved with zero schema
     cost. Needs :global() because bodyHtml is injected via set:html. */
  .prose :global(p:first-of-type) {
    font-size: 1.1rem;
    color: #c9ccd9;
  }
  .prose :global(p) { margin: 0 0 1.2rem; }

  @media (max-width: 640px) {
    .about-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .about-portrait { order: -1; } /* portrait visually leads on mobile, DOM stays text-first */
    .about-portrait img {
      max-width: 320px;
      max-height: 20rem;
      margin: 0 auto;
    }
  }
</style>
