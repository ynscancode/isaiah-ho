---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Band from '../components/Band.astro';

const aboutEntry = await getEntry('site', 'about');
const about = aboutEntry!.data;
---

<BaseLayout
  title="About"
  description="About Isaiah Ho — business student at Singapore Management University, building toward strategy and management consulting."
>
  <Band variant="ink" eyebrow="01 — About">
    <h1>About</h1>
    <div class="prose">
      <p class="lede">
        {about.lede}
      </p>
      {about.paragraphs!.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </Band>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin: 0 0 2rem;
  }

  .prose {
    max-width: 65ch;
  }

  .lede {
    font-size: 1.1rem;
    color: #c9ccd9;
  }

  .prose p {
    margin: 0 0 1.2rem;
  }
</style>
