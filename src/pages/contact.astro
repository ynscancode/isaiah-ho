---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Band from '../components/Band.astro';

const contactEntry = await getEntry('site', 'contact');
const contact = contactEntry!.data;
const links = contact.links ?? [];

const emptyStatesEntry = await getEntry('site', 'emptyStates');
const emptyStateText = emptyStatesEntry?.data.contact ?? 'Coming soon.';
---

<BaseLayout title="Contact" description="Get in touch with Isaiah Ho.">
  <Band variant="ink" eyebrow="05 — Contact">
    <h1>Contact</h1>
    <p class="lede">{contact.lede}</p>
    {links.length > 0 ? (
      <dl class="particulars">
        {links.map((link) => {
          const label =
            link.type === 'email' ? 'Email' : link.type === 'linkedin' ? 'LinkedIn' : link.type === 'github' ? 'GitHub' : link.label;
          const href = link.type === 'email' ? `mailto:${link.value}` : link.value;
          return (
            <div>
              <dt class="mono">{label}</dt>
              {link.value ? <dd><a href={href}>{link.value}</a></dd> : <dd class="coming-soon">Coming soon</dd>}
            </div>
          );
        })}
      </dl>
    ) : (
      <p class="empty-state">{emptyStateText}</p>
    )}
  </Band>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin: 0 0 0.75rem;
  }

  .lede {
    color: #c9ccd9;
    font-size: 1.05rem;
    margin: 0 0 2.5rem;
  }

  .particulars {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    margin: 0;
  }

  .particulars dt {
    color: var(--signal);
    margin-bottom: 0.3rem;
  }

  .particulars dd {
    margin: 0;
    font-size: 1.05rem;
  }

  .particulars a {
    color: var(--paper);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .particulars a:hover {
    color: var(--signal);
  }

  .coming-soon {
    color: #8891ab;
    font-style: italic;
  }
</style>
