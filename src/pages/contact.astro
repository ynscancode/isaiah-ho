---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Band from '../components/Band.astro';

const contactEntry = await getEntry('site', 'contact');
const contact = contactEntry!.data;
---

<BaseLayout title="Contact" description="Get in touch with Isaiah Ho.">
  <Band variant="ink" eyebrow="05 — Contact">
    <h1>Contact</h1>
    <p class="lede">{contact.lede}</p>
    <dl class="particulars">
      <div>
        <dt class="mono">Email</dt>
        {contact.email ? (
          <dd><a href={`mailto:${contact.email}`}>{contact.email}</a></dd>
        ) : (
          <dd class="coming-soon">Coming soon</dd>
        )}
      </div>
      <div>
        <dt class="mono">LinkedIn</dt>
        {contact.linkedin ? (
          <dd><a href={contact.linkedin}>{contact.linkedin}</a></dd>
        ) : (
          <dd class="coming-soon">Coming soon</dd>
        )}
      </div>
      <div>
        <dt class="mono">GitHub</dt>
        {contact.github ? (
          <dd><a href={contact.github}>{contact.github}</a></dd>
        ) : (
          <dd class="coming-soon">Coming soon</dd>
        )}
      </div>
    </dl>
  </Band>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin: 0 0 0.75rem;
  }

  .lede {
    color: #c9ccd9;
    font-size: 1.05rem;
    margin: 0 0 2.5rem;
  }

  .particulars {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    margin: 0;
  }

  .particulars dt {
    color: var(--signal);
    margin-bottom: 0.3rem;
  }

  .particulars dd {
    margin: 0;
    font-size: 1.05rem;
  }

  .particulars a {
    color: var(--paper);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .particulars a:hover {
    color: var(--signal);
  }

  .coming-soon {
    color: #8891ab;
    font-style: italic;
  }
</style>
