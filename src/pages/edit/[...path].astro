---
// The inline WYSIWYG editor shell — tech-lead-20260715T192159 frontend
// contract, section 5. prerender=false so this can read Astro.locals.session
// (populated by src/middleware.ts) at request time; middleware already
// returns a generic 404 for any /edit/** request without a valid session,
// but this route re-checks defensively so the page itself never assumes it
// was reached legitimately (defense in depth, same generic response either
// way — indistinguishable from a genuinely missing route per KB-0007).
//
// URL scheme (mirrors the public site's own routes):
//   /edit                -> home (hero)
//   /edit/about           -> about
//   /edit/contact         -> contact
//   /edit/projects        -> projects collection
//   /edit/experience      -> experience collection
//   /edit/blog             -> blog post list (add/remove)
//   /edit/blog/new          -> create a new post
//   /edit/blog/<slug>       -> edit an existing post
export const prerender = false;

import { loadSiteJson, loadCollectionJson, loadBlogList, loadBlogPost, type ContentSource } from '../../lib/draftContent';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EditorHarness from '../../components/EditorHarness.astro';
import EditHome from '../../components/edit/EditHome.astro';
import EditAbout from '../../components/edit/EditAbout.astro';
import EditContact from '../../components/edit/EditContact.astro';
import EditCollection from '../../components/edit/EditCollection.astro';
import EditBlogList from '../../components/edit/EditBlogList.astro';
import EditBlogPost from '../../components/edit/EditBlogPost.astro';
import EditHistory from '../../components/edit/EditHistory.astro';

function notFound(): Response {
  return new Response('Not found', {
    status: 404,
    headers: { 'content-type': 'text/plain; charset=utf-8' },
  });
}

if (!Astro.locals.session) {
  return notFound();
}

const rawPath = Astro.params.path ?? '';
const segments = rawPath.split('/').filter(Boolean);
const [area, sub] = segments;

let pageTitle = 'Edit';
// eslint-disable-next-line @typescript-eslint/no-explicit-any -- discriminated
// by `view`; the branches above are the sole producers, each shaped to match
// the props of the editor component it's handed to below.
let body: any = null;

// The `source` of whichever loader served the current view — draft-then-
// master-then-build (src/lib/draftContent.ts) — surfaced to the toolbar so
// it can render a sync-state affordance (senior-frontend-dev owns that UI;
// this route only supplies the value it already has at render time).
let contentSource: ContentSource;

// tech-lead-20260718T041814 D2: each view loads only the GitHub reads it
// actually needs, concurrently where more than one is needed. Do NOT
// reintroduce an unconditional top-level loadSiteJson() — that was the
// waste (e.g. blog-post views never use siteData/emptyStates).
function emptyStatesFrom(siteData: Record<string, any>) {
  return {
    projects: siteData.emptyStates?.projects ?? '',
    experience: siteData.emptyStates?.experience ?? '',
    blog: siteData.emptyStates?.blog ?? '',
    contact: siteData.emptyStates?.contact ?? '',
  };
}

if (segments.length === 0) {
  const siteJson = await loadSiteJson();
  contentSource = siteJson.source;
  const siteData = (siteJson.data ?? {}) as Record<string, any>;
  const hero = siteData.home?.hero;
  if (!hero) return notFound();
  pageTitle = 'Edit — Home';
  body = { view: 'home', hero };
} else if (area === 'about' && !sub) {
  const siteJson = await loadSiteJson();
  contentSource = siteJson.source;
  const siteData = (siteJson.data ?? {}) as Record<string, any>;
  const about = siteData.about;
  if (!about) return notFound();
  pageTitle = 'Edit — About';
  body = {
    view: 'about',
    about: { body: about.body ?? '', image: about.image ?? null },
  };
} else if (area === 'contact' && !sub) {
  const siteJson = await loadSiteJson();
  contentSource = siteJson.source;
  const siteData = (siteJson.data ?? {}) as Record<string, any>;
  const contact = siteData.contact;
  if (!contact) return notFound();
  pageTitle = 'Edit — Contact';
  body = {
    view: 'contact',
    contact: {
      lede: contact.lede ?? '',
      links: contact.links ?? [],
    },
    emptyStates: emptyStatesFrom(siteData),
  };
} else if (area === 'projects' && !sub) {
  const [siteJson, result] = await Promise.all([loadSiteJson(), loadCollectionJson('projects')]);
  const siteData = (siteJson.data ?? {}) as Record<string, any>;
  contentSource = result.source;
  pageTitle = 'Edit — Projects';
  body = { view: 'projects', entries: result.data, emptyStates: emptyStatesFrom(siteData) };
} else if (area === 'experience' && !sub) {
  const [siteJson, result] = await Promise.all([loadSiteJson(), loadCollectionJson('experience')]);
  const siteData = (siteJson.data ?? {}) as Record<string, any>;
  contentSource = result.source;
  pageTitle = 'Edit — Experience';
  body = { view: 'experience', entries: result.data, emptyStates: emptyStatesFrom(siteData) };
} else if (area === 'blog' && !sub) {
  const [siteJson, result] = await Promise.all([loadSiteJson(), loadBlogList()]);
  const siteData = (siteJson.data ?? {}) as Record<string, any>;
  contentSource = result.source;
  const sorted = [...result.data].sort((a, b) => b.date.localeCompare(a.date));
  pageTitle = 'Edit — Blog';
  body = {
    view: 'blog-list',
    posts: sorted.map((p) => ({
      id: p.slug,
      title: p.title,
      description: p.description,
      date: new Date(p.date),
      tags: p.tags,
      draft: p.draft,
    })),
    emptyStates: emptyStatesFrom(siteData),
  };
} else if (area === 'history' && !sub) {
  // Version history is fetched client-side from /api/draft/history (see
  // EditHistory.astro) — no server-side draft read needed here, so this
  // route doesn't hit loadSiteJson/loadCollectionJson at all (tech-lead
  // D2: only load what a view actually needs).
  contentSource = 'draft';
  pageTitle = 'Edit — History';
  body = { view: 'history' };
} else if (area === 'blog' && sub === 'new') {
  contentSource = 'draft';
  pageTitle = 'Edit — New blog post';
  body = {
    view: 'blog-post',
    isNew: true,
    post: {
      slug: '',
      title: '',
      description: '',
      date: new Date().toISOString().slice(0, 10),
      draft: true,
      tags: [],
      body: '',
    },
  };
} else if (area === 'blog' && sub) {
  const result = await loadBlogPost(sub);
  contentSource = result.source;
  if (!result.data) return notFound();
  const post = result.data;
  pageTitle = `Edit — ${post.title}`;
  body = {
    view: 'blog-post',
    isNew: false,
    post: {
      slug: post.slug,
      title: post.title,
      description: post.description,
      date: post.date,
      draft: post.draft,
      tags: post.tags,
      body: post.body ?? '',
    },
  };
} else {
  return notFound();
}
---

<BaseLayout title={pageTitle} description="Isaiah Ho — content editor (private).">
  {body?.view === 'home' && <EditHome hero={body.hero} />}
  {body?.view === 'about' && <EditAbout about={body.about} />}
  {body?.view === 'contact' && <EditContact contact={body.contact} emptyStates={body.emptyStates} />}
  {body?.view === 'projects' && (
    <EditCollection area="projects" entries={body.entries} emptyStates={body.emptyStates} />
  )}
  {body?.view === 'experience' && (
    <EditCollection area="experience" entries={body.entries} emptyStates={body.emptyStates} />
  )}
  {body?.view === 'blog-list' && <EditBlogList posts={body.posts} emptyStates={body.emptyStates} />}
  {body?.view === 'blog-post' && <EditBlogPost post={body.post} isNew={body.isNew} />}
  {body?.view === 'history' && <EditHistory />}

  <EditorHarness slot="editor-toolbar" contentSource={contentSource} />
</BaseLayout>
