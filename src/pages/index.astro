---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HeroGraphic from '../components/hero/HeroGraphic.astro';
import Band from '../components/Band.astro';
import Card from '../components/Card.astro';
import { deriveEyebrow } from '../lib/eyebrow';

const allProjects = await getCollection('projects');
const selectedProjects = allProjects.slice(0, 2);

const homeEntry = await getEntry('site', 'home');
const hero = homeEntry!.data.hero!;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const dateFormatter = new Intl.DateTimeFormat('en-SG', { month: 'short', year: 'numeric' });
---

<BaseLayout
  title="Home"
  description="Isaiah Ho — business student at Singapore Management University building toward a career in strategy consulting. Writing, projects, and structured thinking applied to real problems."
>
  <Hero
    eyebrow={hero.eyebrow}
    headlineHtml={hero.headlineHtml}
    lede={hero.lede}
    primaryCta={hero.primaryCta}
    ghostCta={hero.ghostCta}
  >
    <HeroGraphic slot="matrix" default={hero.graphic ?? 'synthesis'} />
  </Hero>

  <Band variant="paper" eyebrow="03 — Selected work">
    <h2>Projects</h2>
    {
      selectedProjects.length > 0 ? (
        <div class="cards">
          {selectedProjects.map((project) => (
            <Card
              eyebrow={deriveEyebrow(project.data.category, project.data.startDate, project.data.endDate)}
              title={project.data.title}
              body={project.data.body}
              href={`/projects#${project.data.slug}`}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">
          {/* TODO(isaiah): add projects to src/data/projects.json — this empty state renders until you do. */}
          No projects yet — check back soon.
        </p>
      )
    }
  </Band>

  <Band variant="paper" divider eyebrow="04 — Latest writing">
    <h2>From the blog</h2>
    {
      latestPosts.length > 0 ? (
        <div class="cards">
          {latestPosts.map((post) => (
            <Card
              eyebrow={dateFormatter.format(post.data.date).toUpperCase()}
              title={post.data.title}
              body={post.data.description}
              href={`/blog/${post.id}`}
              tags={post.data.tags}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">No posts yet — check back soon.</p>
      )
    }
  </Band>
</BaseLayout>
