---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HeroGraphic from '../components/hero/HeroGraphic.astro';
import Band from '../components/Band.astro';
import Card from '../components/Card.astro';
import { deriveEyebrow } from '../lib/eyebrow';

const allProjects = await getCollection('projects');
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const homeEntry = await getEntry('site', 'home');
const hero = homeEntry!.data.hero!;

const dateFormatter = new Intl.DateTimeFormat('en-SG', { month: 'short', year: 'numeric' });

// Homepage Highlights (tech-lead-20260720T113459Z / ui-ux-designer-
// 20260720T120500Z) — a user-curated, manually-ordered mix of projects +
// blog posts, replacing the two auto-recency Bands below. Refs are NEVER
// copied titles; resolve against the live collections IN ORDER, and
// fail-soft: a ref that no longer resolves (deleted project, deleted/
// draft:true post) is silently skipped — never a build error, never a
// broken card (AC7 public side).
const rawHighlights = Array.isArray(homeEntry?.data.highlights) ? homeEntry.data.highlights : [];
type ResolvedHighlight =
  | { kind: 'project'; eyebrow: string; title: string; body: string; href: string }
  | { kind: 'blog'; eyebrow: string; title: string; body: string; href: string; tags: string[] };

const highlights: ResolvedHighlight[] = [];
for (const ref of rawHighlights) {
  if (ref.type === 'project') {
    const project = allProjects.find((p) => p.data.slug === ref.ref);
    if (!project) continue;
    highlights.push({
      kind: 'project',
      eyebrow: `PROJECT · ${deriveEyebrow(project.data.category, project.data.startDate, project.data.endDate)}`,
      title: project.data.title,
      body: project.data.body,
      href: `/projects/${project.data.slug}`,
    });
  } else if (ref.type === 'blog') {
    const post = allPosts.find((p) => p.id === ref.ref);
    if (!post) continue;
    highlights.push({
      kind: 'blog',
      eyebrow: `POST · ${dateFormatter.format(post.data.date).toUpperCase()}`,
      title: post.data.title,
      body: post.data.description,
      href: `/blog/${post.id}`,
      tags: post.data.tags,
    });
  }
}

const emptyStatesEntry = await getEntry('site', 'emptyStates');
const highlightsEmptyText =
  typeof emptyStatesEntry?.data.highlights === 'string'
    ? emptyStatesEntry.data.highlights
    : 'No highlights selected yet — check back soon.';

// Group-by-type render (tech-lead-20260720T160424Z item 4, ratified /
// ui-ux-designer-20260721T050000Z #6-#7). Pure render-time partition of the
// already-resolved, manually-ordered `highlights` — no data/schema change.
// Manual order is preserved WITHIN each type-group. Fail-soft: an empty
// type-group renders nothing (no heading, no grid, no gap). Lone-subhead
// suppression: when only one of the two groups is populated, that group's
// cards render directly under <h2>Highlights</h2> with no "Projects"/"Blog"
// subhead — today's homepage (Blog empty) is visually unchanged.
const projectHighlights = highlights.filter((item) => item.kind === 'project');
const blogHighlights = highlights.filter((item) => item.kind === 'blog');
const showBothSubheads = projectHighlights.length > 0 && blogHighlights.length > 0;
---

<BaseLayout
  title="Home"
  description="Isaiah Ho — business student at Singapore Management University building toward a career in strategy consulting. Writing, projects, and structured thinking applied to real problems."
>
  <Hero
    eyebrow={hero.eyebrow}
    headlineHtml={hero.headlineHtml}
    lede={hero.lede}
    primaryCta={hero.primaryCta}
    ghostCta={hero.ghostCta}
  >
    <HeroGraphic slot="matrix" default={hero.graphic ?? 'synthesis'} />
  </Hero>

  <Band variant="paper">
    <h2>Highlights</h2>
    {
      highlights.length > 0 ? (
        <Fragment>
          {projectHighlights.length > 0 && (
            <div class={showBothSubheads ? 'subgroup subgroup--labeled' : 'subgroup'}>
              {showBothSubheads && <h3 class="mono group-subhead">Projects</h3>}
              <div class="cards">
                {projectHighlights.map((item) => (
                  <Card
                    eyebrow={item.eyebrow}
                    title={item.title}
                    body={item.body}
                    href={item.href}
                  />
                ))}
              </div>
            </div>
          )}
          {blogHighlights.length > 0 && (
            <div class={showBothSubheads ? 'subgroup subgroup--labeled' : 'subgroup'}>
              {showBothSubheads && <h3 class="mono group-subhead">Blog</h3>}
              <div class="cards">
                {blogHighlights.map((item) => (
                  <Card
                    eyebrow={item.eyebrow}
                    title={item.title}
                    body={item.body}
                    href={item.href}
                    tags={item.tags}
                  />
                ))}
              </div>
            </div>
          )}
        </Fragment>
      ) : (
        <p class="empty-state">{highlightsEmptyText}</p>
      )
    }
  </Band>
</BaseLayout>

<style>
  /* Highlights Projects/Blog subgroups (tech-lead-20260720T160424Z item 4 /
     ui-ux-designer-20260721T050000Z #6-#7). Reuses the "group subhead"
     primitive (mono + --signal-text, same family as Band's own .eyebrow).
     Lone-subhead suppression (no `subgroup--labeled` class) keeps the
     single-group case pixel-identical to the pre-grouping render: no extra
     margin, .cards keeps the sitewide 2rem margin-top from global.css. */
  .subgroup:not(:first-of-type) {
    margin-top: 2rem;
    border-top: 1px solid var(--line);
    padding-top: 2rem;
  }

  .group-subhead {
    margin: 0 0 0.6rem;
    color: var(--signal-text);
  }

  .subgroup--labeled .cards {
    margin-top: 1.25rem;
  }
</style>

