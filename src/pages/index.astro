---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HeroGraphic from '../components/hero/HeroGraphic.astro';
import Band from '../components/Band.astro';
import Card from '../components/Card.astro';
import { deriveEyebrow } from '../lib/eyebrow';

const allProjects = await getCollection('projects');
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const homeEntry = await getEntry('site', 'home');
const hero = homeEntry!.data.hero!;

const dateFormatter = new Intl.DateTimeFormat('en-SG', { month: 'short', year: 'numeric' });

// Homepage Highlights (tech-lead-20260720T113459Z / ui-ux-designer-
// 20260720T120500Z) — a user-curated, manually-ordered mix of projects +
// blog posts, replacing the two auto-recency Bands below. Refs are NEVER
// copied titles; resolve against the live collections IN ORDER, and
// fail-soft: a ref that no longer resolves (deleted project, deleted/
// draft:true post) is silently skipped — never a build error, never a
// broken card (AC7 public side).
const rawHighlights = Array.isArray(homeEntry?.data.highlights) ? homeEntry.data.highlights : [];
type ResolvedHighlight =
  | { kind: 'project'; eyebrow: string; title: string; body: string; href: string }
  | { kind: 'blog'; eyebrow: string; title: string; body: string; href: string; tags: string[] };

const highlights: ResolvedHighlight[] = [];
for (const ref of rawHighlights) {
  if (ref.type === 'project') {
    const project = allProjects.find((p) => p.data.slug === ref.ref);
    if (!project) continue;
    highlights.push({
      kind: 'project',
      eyebrow: `PROJECT · ${deriveEyebrow(project.data.category, project.data.startDate, project.data.endDate)}`,
      title: project.data.title,
      body: project.data.body,
      href: `/projects/${project.data.slug}`,
    });
  } else if (ref.type === 'blog') {
    const post = allPosts.find((p) => p.id === ref.ref);
    if (!post) continue;
    highlights.push({
      kind: 'blog',
      eyebrow: `POST · ${dateFormatter.format(post.data.date).toUpperCase()}`,
      title: post.data.title,
      body: post.data.description,
      href: `/blog/${post.id}`,
      tags: post.data.tags,
    });
  }
}

const emptyStatesEntry = await getEntry('site', 'emptyStates');
const highlightsEmptyText =
  typeof emptyStatesEntry?.data.highlights === 'string'
    ? emptyStatesEntry.data.highlights
    : 'No highlights selected yet — check back soon.';
---

<BaseLayout
  title="Home"
  description="Isaiah Ho — business student at Singapore Management University building toward a career in strategy consulting. Writing, projects, and structured thinking applied to real problems."
>
  <Hero
    eyebrow={hero.eyebrow}
    headlineHtml={hero.headlineHtml}
    lede={hero.lede}
    primaryCta={hero.primaryCta}
    ghostCta={hero.ghostCta}
  >
    <HeroGraphic slot="matrix" default={hero.graphic ?? 'synthesis'} />
  </Hero>

  <Band variant="paper" eyebrow="Highlights">
    <h2>Highlights</h2>
    {
      highlights.length > 0 ? (
        <div class="cards">
          {highlights.map((item) => (
            <Card
              eyebrow={item.eyebrow}
              title={item.title}
              body={item.body}
              href={item.href}
              tags={item.kind === 'blog' ? item.tags : undefined}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">{highlightsEmptyText}</p>
      )
    }
  </Band>
</BaseLayout>
