---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Band from '../components/Band.astro';
import Card from '../components/Card.astro';
import { deriveEyebrow } from '../lib/eyebrow';

const projects = await getCollection('projects');

const emptyStatesEntry = await getEntry('site', 'emptyStates');
const emptyStateText = emptyStatesEntry?.data.projects ?? 'Coming soon.';
---

<BaseLayout
  title="Projects"
  description="Case competitions, research, and independent projects by Isaiah Ho."
>
  <Band variant="paper">
    <h1>Projects</h1>
    {
      projects.length > 0 ? (
        <div class="cards">
          {projects.map((project) => (
            <div id={project.data.slug}>
              <Card
                eyebrow={deriveEyebrow(project.data.category, project.data.startDate, project.data.endDate)}
                title={project.data.title}
                body={project.data.body}
                href={project.data.href}
              />
            </div>
          ))}
        </div>
      ) : (
        <p class="empty-state">{emptyStateText}</p>
      )
    }
  </Band>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem;
  }
</style>
