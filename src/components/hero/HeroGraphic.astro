---
/**
 * Hero graphic orchestrator — placed in Hero's `matrix` slot.
 * Renders all four motifs at build time; the chosen `default` variant is
 * un-hidden via a build-time `hidden` attribute on the others, so the public
 * render is correct with ZERO runtime JS. The variant is chosen in the
 * editor (src/components/edit/EditHome.astro's graphic picker), which toggles
 * these same `[data-hero-variant]` elements and persists the choice to
 * site.json's `hero.graphic`; the public page passes it in as `default`.
 */
import HeroRadar from './HeroRadar.astro';
import HeroRotation from './HeroRotation.astro';
import HeroSynthesis from './HeroSynthesis.astro';
import HeroOrbit from './HeroOrbit.astro';
import { DEFAULT_HERO_VARIANT, type HeroVariant } from '../../lib/heroVariants';

export type Props = {
  default?: HeroVariant;
};

const { default: defaultVariant = DEFAULT_HERO_VARIANT } = Astro.props;
---

<div class="hero-graphic-canvas">
  <div class="hero-variant" data-hero-variant="radar" hidden={defaultVariant !== 'radar'}>
    <HeroRadar />
  </div>
  <div class="hero-variant" data-hero-variant="rotation" hidden={defaultVariant !== 'rotation'}>
    <HeroRotation />
  </div>
  <div class="hero-variant" data-hero-variant="synthesis" hidden={defaultVariant !== 'synthesis'}>
    <HeroSynthesis />
  </div>
  <div class="hero-variant" data-hero-variant="orbit" hidden={defaultVariant !== 'orbit'}>
    <HeroOrbit />
  </div>
</div>

<style>
  .hero-graphic-canvas {
    position: relative;
    width: 100%;
    max-width: 380px;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    padding: 8%;
    border-radius: 4px;
    background: radial-gradient(120% 120% at 30% 20%, #171f36, #12182b 70%);
  }

  .hero-variant {
    width: 100%;
    height: 100%;
  }

  .hero-variant :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
