---
/**
 * Hero graphic orchestrator — placed in Hero's `matrix` slot.
 * Per tech-lead-20260719T153953: renders all three motifs at build time;
 * the DEFAULT variant is un-hidden via a build-time `hidden` attribute on
 * the other two, so the bare `/` render is correct with ZERO JS. The one
 * runtime <script> below is a tiny, self-contained, trivially-removable
 * preview-swap aid gated on a `?hero=` query param — it never runs (and
 * the floating switcher never renders) unless that param is present.
 */
import HeroRadar from './HeroRadar.astro';
import HeroRotation from './HeroRotation.astro';
import HeroSynthesis from './HeroSynthesis.astro';
import HeroOrbit from './HeroOrbit.astro';

export type Props = {
  default?: 'radar' | 'rotation' | 'synthesis' | 'orbit';
};

const { default: defaultVariant = 'synthesis' } = Astro.props;
---

<div class="hero-graphic-canvas">
  <div class="hero-variant" data-hero-variant="radar" hidden={defaultVariant !== 'radar'}>
    <HeroRadar />
  </div>
  <div class="hero-variant" data-hero-variant="rotation" hidden={defaultVariant !== 'rotation'}>
    <HeroRotation />
  </div>
  <div class="hero-variant" data-hero-variant="synthesis" hidden={defaultVariant !== 'synthesis'}>
    <HeroSynthesis />
  </div>
  <div class="hero-variant" data-hero-variant="orbit" hidden={defaultVariant !== 'orbit'}>
    <HeroOrbit />
  </div>
</div>

<style>
  .hero-graphic-canvas {
    position: relative;
    width: 100%;
    max-width: 380px;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    padding: 8%;
    border-radius: 4px;
    background: radial-gradient(120% 120% at 30% 20%, #171f36, #12182b 70%);
  }

  .hero-variant {
    width: 100%;
    height: 100%;
  }

  .hero-variant :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Preview switcher — only rendered/shown when a `?hero=` param is
     present (see the script below). Deliberately styled to NOT look like
     site chrome: a small, low-contrast, mono debug strip. */
  .hero-graphic-switcher {
    display: none;
    position: fixed;
    left: 50%;
    bottom: 1.25rem;
    transform: translateX(-50%);
    z-index: 40;
    gap: 0.4rem;
    padding: 0.5rem;
    border-radius: 4px;
    background: rgba(18, 24, 43, 0.92);
    border: 1px solid #34406b;
  }

  .hero-graphic-switcher.is-active {
    display: flex;
  }

  .hero-graphic-switcher button {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: #b7bdcc;
    background: transparent;
    border: 1px solid #34406b;
    border-radius: 3px;
    padding: 0.35rem 0.55rem;
    cursor: pointer;
  }

  .hero-graphic-switcher button[aria-pressed="true"] {
    color: #12182b;
    background: #e0a94a;
    border-color: #e0a94a;
  }

  .hero-graphic-switcher button:focus-visible {
    outline: 2px solid #f5f3ee;
    outline-offset: 2px;
  }
</style>

<script>
  // Self-contained, trivially removable in one block: reads `?hero=` to
  // toggle which build-time-rendered variant is visible, and renders a
  // small floating switcher ONLY when the param is present. No effect at
  // all on the default `/` render (no param => this script is a no-op
  // besides the initial param read).
  const VARIANTS = ['radar', 'rotation', 'synthesis', 'orbit'] as const;
  type Variant = (typeof VARIANTS)[number];

  function isVariant(v: string | null): v is Variant {
    return !!v && (VARIANTS as readonly string[]).includes(v);
  }

  const canvas = document.querySelector<HTMLElement>('.hero-graphic-canvas');
  if (canvas) {
    const params = new URLSearchParams(location.search);
    const requested = params.get('hero');

    function show(variant: Variant) {
      for (const v of VARIANTS) {
        const el = canvas!.querySelector<HTMLElement>(`[data-hero-variant="${v}"]`);
        if (el) el.hidden = v !== variant;
      }
    }

    if (isVariant(requested)) {
      show(requested);

      const switcher = document.createElement('div');
      switcher.className = 'hero-graphic-switcher is-active';
      switcher.setAttribute('role', 'group');
      switcher.setAttribute('aria-label', 'Preview hero graphic variant');

      let current: Variant = requested;

      for (const v of VARIANTS) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = `Show ${v}`;
        btn.setAttribute('aria-pressed', String(v === current));
        btn.addEventListener('click', () => {
          current = v;
          show(v);
          const url = new URL(location.href);
          url.searchParams.set('hero', v);
          history.replaceState(null, '', url);
          switcher.querySelectorAll('button').forEach((b) => {
            b.setAttribute('aria-pressed', String(b === btn));
          });
        });
        switcher.appendChild(btn);
      }

      document.body.appendChild(switcher);
    }
  }
</script>
