---
/**
 * Rotation motif — concentric spinning squares, pure CSS, no runtime JS.
 *
 * Geometry (nesting invariant): consecutive squares are scaled by exactly
 * √2 (each outer = inner × 1.41421…), so a rotating inner square's corners
 * reach precisely its neighbour's edge distance and never poke through —
 * the classic "corners just fit inside the next square" nesting, holding at
 * every relative rotation. Half-widths: 140, 99, 70, 49.5, 35, 24.75 →
 * widths 280, 198, 140, 99, 70, 49.5. The outermost corner reach is
 * 140·√2 ≈ 198 < 200, so it also stays inside the 400×400 viewBox.
 *
 * Counting from the innermost box outward (1→6): the amber box (#c87f0a)
 * is the 4th (width 140); the dot rides the 2nd (width 70, non-amber),
 * travelling that box's edge opposite to its spin. aria-label matches.
 */
---

<svg viewBox="0 0 400 400" role="img" aria-label="Concentric squares nested at a 45-degree scale; the fourth box from inside is amber, a dot rides the non-amber second box the opposite way to its spin">
  <rect class="sq" x="60" y="60" width="280" height="280" fill="none" stroke="#34406b" stroke-width="1.4" style="animation-name:spin; animation-duration:32s; animation-delay:-13s"></rect>
  <rect class="sq" x="101" y="101" width="198" height="198" fill="none" stroke="#34406b" stroke-width="1.4" style="animation-name:spin-rev; animation-duration:38s; animation-delay:-5s"></rect>
  <rect class="sq" x="130" y="130" width="140" height="140" fill="none" stroke="#c87f0a" stroke-width="1.7" style="animation-name:spin; animation-duration:25s; animation-delay:-19s"></rect>
  <rect class="sq" x="150.5" y="150.5" width="99" height="99" fill="none" stroke="#34406b" stroke-width="1.4" style="animation-name:spin-rev; animation-duration:42s; animation-delay:-8s"></rect>
  <g class="sq" style="animation-name:spin; animation-duration:21s; animation-delay:-22s">
    <rect x="165" y="165" width="70" height="70" fill="none" stroke="#34406b" stroke-width="1.4"></rect>
    <circle class="rot-dot-halo" cx="0" cy="0" r="10" fill="rgba(200,127,10,0.22)" style={`offset-path:path('M165,165 H235 V235 H165 Z'); animation:headmove 8s linear infinite reverse, rot-node-pulse 2.8s ease-in-out infinite`}></circle>
    <circle class="rot-dot" cx="0" cy="0" r="4.5" fill="#e0a94a" style={`offset-path:path('M165,165 H235 V235 H165 Z'); animation:headmove 8s linear infinite reverse`}></circle>
  </g>
  <rect class="sq" x="175.25" y="175.25" width="49.5" height="49.5" fill="none" stroke="#34406b" stroke-width="1.4" style="animation-name:spin-rev; animation-duration:30s; animation-delay:-3s"></rect>
  <circle cx="200" cy="200" r="2.5" fill="#8891ab"></circle>
</svg>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes spin-rev {
    from { transform: rotate(0deg); }
    to { transform: rotate(-360deg); }
  }
  .sq {
    transform-box: view-box;
    transform-origin: 200px 200px;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  @keyframes headmove {
    from { offset-distance: 0%; }
    to { offset-distance: 100%; }
  }
  .rot-dot,
  .rot-dot-halo {
    offset-rotate: 0deg;
  }

  /* Pulsing glow on the dot's halo, mirroring HeroSynthesis's convergence
     node (node-pulse: opacity 0.45->0.85, scale 1->1.18, 2.8s ease-in-out).
     The halo runs two animations at once — `headmove` moves it along the
     square's edge (offset-distance), `rot-node-pulse` breathes it (transform
     scale + opacity); they animate different properties so they compose. */
  @keyframes rot-node-pulse {
    0%, 100% { opacity: 0.45; transform: scale(1); }
    50% { opacity: 0.85; transform: scale(1.18); }
  }
  .rot-dot-halo {
    transform-box: fill-box;
    transform-origin: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .sq {
      animation: none;
    }
    .rot-dot,
    .rot-dot-halo {
      animation: none;
      offset-distance: 12%;
    }
  }
</style>
