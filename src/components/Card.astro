---
export type Props = {
  /** Required on the public (non-editable) branch; unused in editable mode,
   * which instead renders the category/date-picker fields below. */
  eyebrow?: string;
  title: string;
  body: string;
  href?: string;
  /** Optional expanded description. When present (and the card is
   * non-editable) the card renders as a native <details>/<summary>
   * disclosure — see tech-lead-20260720T051637 §2. */
  detail?: string;
  tags?: string[];
  /** Editor-only, defaults false — see Hero.astro's comment for the
   * public-build-is-byte-identical rationale. When true the card is forced
   * to a <div> (never <a>) so it isn't a live navigation target while being
   * edited, and gains contenteditable text fields, an "edit link" button
   * for `href`, and a remove-entry button. `editablePrefix` is the entry's
   * stable id (not its array index — see EditCollection.astro for why:
   * ids survive another entry being removed, positions don't) used to
   * build each data-editable path as `${editablePrefix}.<field>`. */
  editable?: boolean;
  editablePrefix?: string;
  removable?: boolean;
  /** Editable-mode-only fields (product-owner-20260717T200000 Decision 2 /
   * ui-ux-designer-20260717T210000 section 4). Public callers keep passing
   * the derived `eyebrow` string exactly as before — these are unused on
   * the non-editable branch. */
  category?: string;
  startDate?: string | null;
  endDate?: string | null;
};

const {
  eyebrow = '',
  title,
  body,
  href,
  detail = '',
  tags = [],
  editable = false,
  editablePrefix = '',
  removable = false,
  category = '',
  startDate = null,
  endDate = null,
} = Astro.props;
// Only the public (non-editable) render may disclose — the editable branch
// stays <div> unconditionally so <details> never reaches the editor
// (ARCH-0005, tech-lead-20260720T051637 §2).
const hasDetail = !editable && detail.trim().length > 0;
const Tag = editable ? 'div' : hasDetail ? 'details' : href ? 'a' : 'div';
---

<Tag
  class="card"
  style={editable ? 'position:relative' : undefined}
  {...(!editable && !hasDetail && href ? { href } : {})}
>
  {editable && removable && (
    <button type="button" class="card-remove-btn" data-remove-entry={editablePrefix} aria-label={`Remove ${title || 'entry'}`}>
      Remove
    </button>
  )}
  {hasDetail ? (
    <>
      <summary>
        <span class="mono card-eyebrow">{eyebrow}</span>
        <h3>{title}</h3>
        <p>{body}</p>
        <span class="card-cue mono" aria-hidden="true">Details ↓</span>
      </summary>
      <div class="card-detail">
        <p>{detail}</p>
        {href && (
          <a class="card-detail-link mono" href={href} target="_blank" rel="noopener">View project ↗</a>
        )}
      </div>
    </>
  ) : (
    <>
      {editable ? (
        <>
          <span
            class="mono card-eyebrow"
            contenteditable="true"
            data-editable={`${editablePrefix}.category`}
            data-placeholder="e.g. Internship, Case competition, Leadership"
          >{category}</span>
          <div class="editor-inline-controls card-date-fields">
            <div>
              <label class="editor-field-label mono">Start</label>
              <input type="date" class="editor-input card-date-input" value={startDate ?? ''} data-editable={`${editablePrefix}.startDate`} />
            </div>
            <div>
              <label class="editor-field-label mono">End</label>
              <input type="date" class="editor-input card-date-input" value={endDate ?? ''} data-editable={`${editablePrefix}.endDate`} />
            </div>
          </div>
        </>
      ) : (
        <span class="mono card-eyebrow">{eyebrow}</span>
      )}
      <h3
        data-editable={editable ? `${editablePrefix}.title` : undefined}
        data-placeholder={editable ? 'Untitled' : undefined}
        contenteditable={editable ? 'true' : undefined}
      >{title}</h3>
      <p
        data-editable={editable ? `${editablePrefix}.body` : undefined}
        data-placeholder={editable ? 'One or two sentences on scope and impact.' : undefined}
        contenteditable={editable ? 'true' : undefined}
      >{body}</p>
      {editable && (
        <p
          class="card-detail-edit"
          data-editable={`${editablePrefix}.detail`}
          data-placeholder="Longer description shown when the card is expanded (optional)."
          contenteditable="true"
        >{detail}</p>
      )}
      {editable && (
        <p class="mono card-href-field">
          link: <span data-editable-href-value={`${editablePrefix}.href`}>{href || '(none)'}</span>
          <button type="button" class="edit-href-btn" data-editable-href={`${editablePrefix}.href`} data-nullable="true">edit link</button>
        </p>
      )}
      {tags.length > 0 && (
        <ul class="mono card-tags">
          {tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )}
      {!editable && href && (
        <span class="card-cue mono" aria-hidden="true">Read →</span>
      )}
    </>
  )}
</Tag>

<style>
  .card {
    --focus-ring: 2px solid var(--ink);
    display: block;
    border: 1px solid var(--line);
    padding: 1.6rem;
    border-radius: 4px;
    background: #fdfcfa;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  a.card,
  details.card {
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }

  a.card:hover,
  details.card:not([open]):hover {
    border-color: var(--signal);
    transform: translateY(-3px);
    box-shadow: 0 6px 16px rgba(18, 24, 43, 0.1);
  }

  @media (prefers-reduced-motion: reduce) {
    a.card:hover,
    details.card:not([open]):hover {
      transform: none;
      box-shadow: none;
    }
  }

  details.card summary {
    cursor: pointer;
    list-style: none;
  }

  details.card summary::-webkit-details-marker {
    display: none;
  }

  details.card summary:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 2px;
  }

  .card-detail {
    margin-top: 1rem;
  }

  .card-detail-link {
    display: block;
    margin-top: 0.9rem;
    font-size: 0.78rem;
    color: var(--signal-text);
    letter-spacing: 0.02em;
  }

  .card-detail-edit {
    margin-top: 0.6rem;
  }

  .card-eyebrow {
    color: var(--slate);
    margin-bottom: 0.8rem;
  }

  .card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
  }

  .card p {
    margin: 0;
    color: var(--slate);
    font-size: 0.95rem;
    font-family: "Source Serif 4", serif;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0.9rem 0 0;
    padding: 0;
  }

  .card-tags li {
    color: var(--signal-text);
  }

  .card-cue {
    display: block;
    margin-top: 0.9rem;
    font-size: 0.78rem;
    color: var(--signal-text);
    letter-spacing: 0.02em;
  }
</style>
