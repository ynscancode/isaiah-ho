---
import { getEntry } from 'astro:content';

// Build-time year — used as the rendered fallback so the copyright is correct
// with JavaScript disabled and for crawlers. On a STATIC site this value is
// frozen at build time, so the inline script below refreshes it to the
// visitor's actual current year on load (covers the site sitting un-rebuilt
// across a New Year).
const year = new Date().getFullYear();

const contactEntry = await getEntry('site', 'contact');
const links = contactEntry?.data.links ?? [];

function labelFor(link: { type: 'email' | 'linkedin' | 'github' | 'other'; label: string }): string {
  if (link.type === 'email') return 'Email';
  if (link.type === 'linkedin') return 'LinkedIn';
  if (link.type === 'github') return 'GitHub';
  return link.label;
}
---

<footer>
  <span>&copy; <span id="footer-year">{year}</span> Isaiah Ho</span>
  <span>
    {links.map((link, i) => (
      <>
        {i > 0 && ' · '}
        {link.value ? (
          <a href={link.type === 'email' ? `mailto:${link.value}` : link.value}>{link.value}</a>
        ) : (
          <span class="coming-soon">{labelFor(link)} · Coming soon</span>
        )}
      </>
    ))}
  </span>
</footer>

<script is:inline>
  // Keep the copyright year current in the visitor's browser regardless of
  // when the static site was last built. Falls back silently to the
  // build-time year if this doesn't run.
  (function () {
    var el = document.getElementById('footer-year');
    if (el) el.textContent = String(new Date().getFullYear());
  })();
</script>

<style>
  footer {
    --focus-ring: 2px solid var(--paper);
    background: var(--ink);
    color: #8891ab;
    padding: 2rem 2.5rem;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.75rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  a {
    color: #c9ccd9;
  }

  .coming-soon {
    color: #6b7280;
    font-style: italic;
  }
</style>
