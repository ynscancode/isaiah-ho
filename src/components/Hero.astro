---
export type Props = {
  eyebrow: string;
  headlineHtml: string;
  lede: string;
  primaryCta: { label: string; href: string };
  ghostCta: { label: string; href: string };
};

const { eyebrow, headlineHtml, lede, primaryCta, ghostCta } = Astro.props;
---

<div class="hero">
  <div class="hero-copy">
    <span class="eyebrow mono">{eyebrow}</span>
    <h1 set:html={headlineHtml} />
    <p class="lede">{lede}</p>
    <div class="btn-row">
      <a class="btn btn-primary" href={primaryCta.href}>{primaryCta.label}</a>
      <a class="btn btn-ghost" href={ghostCta.href}>{ghostCta.label}</a>
    </div>
  </div>
  <div class="hero-matrix">
    <slot name="matrix" />
  </div>
</div>

<style>
  .hero {
    --focus-ring: 2px solid var(--paper);
    background: var(--ink);
    color: var(--paper);
    padding: 5rem 2.5rem 6rem;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 3rem;
    align-items: center;
  }

  .eyebrow {
    color: var(--signal);
    margin-bottom: 1rem;
    display: block;
  }

  h1 {
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    margin: 0 0 1.2rem;
    line-height: 1.05;
  }

  .lede {
    font-family: "Source Serif 4", serif;
    font-size: 1.15rem;
    color: #c9ccd9;
    max-width: 34ch;
    margin: 0 0 2rem;
  }

  .btn-row {
    display: flex;
    gap: 1rem;
  }

  .btn {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.9rem;
    padding: 0.75rem 1.4rem;
    border-radius: 2px;
    text-decoration: none;
    display: inline-block;
  }

  .btn-primary {
    background: var(--signal);
    color: var(--ink);
    font-weight: 600;
  }

  .btn-ghost {
    border: 1px solid #5f6990;
    color: var(--paper);
  }

  @media (min-width: 900px) {
    /* The matrix's rotated axis-left/axis-right labels (PositioningMatrix.astro)
       sit outside the matrix box at left:-3.6rem / right:-4.4rem. Reserve at
       least that much room inside the matrix's own grid column so the labels
       land inside the viewport instead of spilling past the hero's padding
       (KB-0004: an out-of-flow/absolutely-positioned element isn't accounted
       for in its parent's width, so its space must be reserved explicitly). */
    .hero-matrix {
      padding: 0 4.8rem 0 4rem;
    }
  }

  @media (max-width: 899px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem 3.5rem;
    }

    /* KB-0004: flex-column defaults to align-items:stretch, sizing every
       child to the widest sibling — constrain cross-axis per button. */
    .btn-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .btn-row .btn {
      align-self: flex-start;
    }

    .hero-matrix {
      justify-self: center;
      width: 100%;
    }
  }
</style>
