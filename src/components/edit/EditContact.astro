---
import Band from '../Band.astro';

export type ContactLink = {
  id: string;
  type: 'email' | 'linkedin' | 'github' | 'other';
  label: string;
  value: string;
};

export type Props = {
  contact: { lede: string; links: ContactLink[] };
  emptyStates: { projects: string; experience: string; blog: string; contact: string };
};

const { contact, emptyStates } = Astro.props;
---

<Band variant="ink" as="div">
  <h1>Contact</h1>
  <p class="lede" data-editable="lede" contenteditable="true" data-editable-area="contact">{contact.lede}</p>

  <div class="contact-links-list" data-editable-area="contact-links">
    {contact.links.map((link) => (
      <div class="contact-link-row" data-link-id={link.id}>
        <button type="button" class="card-remove-btn contact-link-remove" data-remove-link={link.id} aria-label="Remove this link">Remove</button>

        <label class="editor-field-label mono">Type</label>
        <select class="editor-input contact-link-type" data-link-field={`${link.id}.type`}>
          <option value="email" selected={link.type === 'email'}>Email</option>
          <option value="linkedin" selected={link.type === 'linkedin'}>LinkedIn</option>
          <option value="github" selected={link.type === 'github'}>GitHub</option>
          <option value="other" selected={link.type === 'other'}>Other</option>
        </select>

        <label class="editor-field-label mono">Label</label>
        <input class="editor-input contact-link-label" type="text"
          placeholder="e.g. Twitter, Calendly"
          value={link.label} data-link-field={`${link.id}.label`}
          disabled={link.type !== 'other'} />

        <label class="editor-field-label mono">Value</label>
        <input class="editor-input contact-link-value" type="text"
          placeholder={link.type === 'email' ? 'name@example.com' : 'https://...'}
          value={link.value} data-link-field={`${link.id}.value`} />
        <p class="contact-link-hint" data-link-hint={link.id} hidden>Finish the URL (or email) to save this link — it won't be lost, just held until it's complete.</p>
      </div>
    ))}
  </div>
  <button type="button" class="editor-add-btn" id="add-contact-link">+ Add contact link</button>
  {contact.links.length === 0 && (
    <p class="editor-note">No contact links yet — click "+ Add contact link" to add one.</p>
  )}

  <hr class="editor-divider" />
  <label class="editor-field-label mono" for="empty-state-text">Empty-state message</label>
  <input id="empty-state-text" class="editor-input" type="text" value={emptyStates.contact} data-editable="emptyState" />
  <p class="editor-note">Shown on the public page in place of the list when this section has zero entries.</p>
</Band>

<script define:vars={{ links: contact.links, emptyStates }}>
  window.__editorSeed = window.__editorSeed || {};
  window.__editorSeed.contactLinks = links;
  window.__editorSeed.emptyStates = emptyStates;
</script>

<script>
  import { makeAutosaver, saveArea, uniqueId } from '../../lib/editor/client';
  import type { ContactLink } from './EditContact.astro';
  import { unregister, wireField } from '../../lib/editor/history';
  import { isPersistableContactValue } from '../../lib/contactValue';

  const AREA = 'contact';
  const ledeEl = document.querySelector<HTMLElement>('[data-editable="lede"][data-editable-area="contact"]');
  const list = document.querySelector<HTMLElement>('[data-editable-area="contact-links"]');

  if (ledeEl && list) {
    const seedLinks = (window as unknown as { __editorSeed: { contactLinks: ContactLink[] } }).__editorSeed
      .contactLinks;
    const working = new Map<string, ContactLink>(seedLinks.map((link) => [link.id, { ...link }]));

    // tech-lead-20260718T174921 Design B: never TRANSMIT a not-yet-plausibly-
    // complete link value. Tracks the last value the server actually
    // accepted for each link, so an in-progress keystroke can be held back
    // in the outgoing payload without losing the previously-saved value.
    const lastPersistedValue = new Map<string, string>(seedLinks.map((link) => [link.id, link.value]));

    function updateHint(id: string) {
      const hintEl = list!.querySelector<HTMLElement>(`[data-link-hint="${id}"]`);
      if (!hintEl) return;
      const entry = working.get(id);
      if (!entry) return;
      const held = entry.value !== '' && !isPersistableContactValue(entry.type, entry.value);
      hintEl.hidden = !held;
    }

    const autosaver = makeAutosaver({
      save: async () => {
        const payloadLinks = Array.from(working.values()).map((link) => {
          const persistable = isPersistableContactValue(link.type, link.value);
          const value = persistable ? link.value : (lastPersistedValue.get(link.id) ?? '');
          return { ...link, value };
        });
        const payload = { lede: ledeEl!.textContent ?? '', links: payloadLinks };
        const result = await saveArea(AREA, payload);
        if (result.ok) {
          for (const link of payloadLinks) lastPersistedValue.set(link.id, link.value);
        }
        return result;
      },
    });

    ledeEl.addEventListener('input', () => {
      autosaver.markDirty();
    });

    wireField({
      id: 'contact:lede',
      el: ledeEl,
      getValue: () => ledeEl!.textContent ?? '',
      setValue: (value) => {
        ledeEl!.textContent = value;
      },
      onApply: () => void autosaver.flush(), // undo/redo apply
    });

    // commit(historyId) (wireField's own blur listener above) runs first;
    // this second blur listener (registered after) fires next.
    ledeEl.addEventListener('blur', () => {
      void autosaver.flush();
    });

    function fieldOf(el: HTMLElement): { id: string; field: keyof ContactLink } | null {
      const attr = el.getAttribute('data-link-field');
      if (!attr) return null;
      const dot = attr.indexOf('.');
      if (dot === -1) return null;
      return { id: attr.slice(0, dot), field: attr.slice(dot + 1) as keyof ContactLink };
    }

    function wireRow(row: HTMLElement) {
      const typeEl = row.querySelector<HTMLSelectElement>('.contact-link-type');
      const labelEl = row.querySelector<HTMLInputElement>('.contact-link-label');
      const valueEl = row.querySelector<HTMLInputElement>('.contact-link-value');

      function applyTypeChange(focusLabel: boolean) {
        if (!typeEl) return;
        const target = fieldOf(typeEl);
        if (!target) return;
        const entry = working.get(target.id);
        if (!entry) return;
        entry.type = typeEl.value as ContactLink['type'];
        if (labelEl) {
          labelEl.disabled = entry.type !== 'other';
          if (focusLabel && entry.type === 'other' && labelEl.value.trim().length === 0) {
            labelEl.focus();
          }
        }
        if (valueEl) {
          valueEl.placeholder = entry.type === 'email' ? 'name@example.com' : 'https://...';
        }
        if (target) updateHint(target.id);
        void autosaver.flush(); // <select> change (or undo/redo apply) — discrete commit
      }

      labelEl?.addEventListener('input', () => {
        const target = fieldOf(labelEl);
        if (!target) return;
        const entry = working.get(target.id);
        if (!entry) return;
        entry.label = labelEl.value;
        autosaver.markDirty();
      });

      valueEl?.addEventListener('input', () => {
        const target = fieldOf(valueEl);
        if (!target) return;
        const entry = working.get(target.id);
        if (!entry) return;
        entry.value = valueEl.value;
        // isPersistableContactValue hold-at-last-persisted logic (Design B,
        // tech-lead-20260718T174921) stays: an incomplete mid-typed URL/email
        // is never TRANSMITTED (see autosaver.save() above, which substitutes
        // lastPersistedValue while held). The immediate-flush-on-becoming-
        // persistable special case is removed — blur below now covers the
        // just-finished value (tech-lead-20260720T041354).
        updateHint(target.id);
        autosaver.markDirty();
      });

      // Item 5: per-field undo/redo for this row's controls. Structural
      // (add/remove-row) undo is deferred (tech-lead-20260718T082028 /
      // PO AC7) — unregister() below just makes a stale step for a removed
      // row a safe no-op rather than corrupting `working`. Each wireField()
      // call registers the field's own commit(historyId) listener (change
      // for type, blur for label/value); the explicit change/blur→flush
      // listener added right after each one fires SECOND (DOM listener
      // order), so commit() always snapshots the undo step before flush()
      // performs the git commit.
      const rowId = row.getAttribute('data-link-id');
      if (rowId && typeEl) {
        wireField({
          id: `contact:link:${rowId}.type`,
          el: typeEl,
          getValue: () => typeEl.value,
          setValue: (value) => {
            typeEl.value = value;
          },
          onApply: () => applyTypeChange(false),
          commitEvent: 'change',
        });
        typeEl.addEventListener('change', () => applyTypeChange(true));
      }
      if (rowId && labelEl) {
        wireField({
          id: `contact:link:${rowId}.label`,
          el: labelEl,
          getValue: () => labelEl.value,
          setValue: (value) => {
            labelEl.value = value;
          },
          onApply: () => {
            const target = fieldOf(labelEl);
            const entry = target && working.get(target.id);
            if (entry) entry.label = labelEl.value;
            void autosaver.flush(); // undo/redo apply
          },
        });
        labelEl.addEventListener('blur', () => {
          void autosaver.flush();
        });
      }
      if (rowId && valueEl) {
        wireField({
          id: `contact:link:${rowId}.value`,
          el: valueEl,
          getValue: () => valueEl.value,
          setValue: (value) => {
            valueEl.value = value;
          },
          onApply: () => {
            const target = fieldOf(valueEl);
            const entry = target && working.get(target.id);
            if (entry) entry.value = valueEl.value;
            if (target) updateHint(target.id);
            void autosaver.flush(); // undo/redo apply
          },
        });
        valueEl.addEventListener('blur', () => {
          void autosaver.flush();
        });
      }

      const removeBtn = row.querySelector<HTMLButtonElement>('[data-remove-link]');
      removeBtn?.addEventListener('click', () => {
        const id = removeBtn.getAttribute('data-remove-link');
        if (!id) return;
        if (!window.confirm('Remove this contact link?')) return;
        working.delete(id);
        lastPersistedValue.delete(id);
        row.remove();
        unregister(`contact:link:${id}.type`);
        unregister(`contact:link:${id}.label`);
        unregister(`contact:link:${id}.value`);
        void autosaver.flush(); // deletion — discrete commit
      });
    }

    list.querySelectorAll<HTMLElement>('.contact-link-row').forEach(wireRow);

    const addBtn = document.getElementById('add-contact-link');
    addBtn?.addEventListener('click', () => {
      const id = uniqueId();
      const newLink: ContactLink = { id, type: 'other', label: '', value: '' };
      working.set(id, newLink);
      lastPersistedValue.set(id, '');

      const row = document.createElement('div');
      row.className = 'contact-link-row';
      row.setAttribute('data-link-id', id);
      row.innerHTML = `
        <button type="button" class="card-remove-btn contact-link-remove" data-remove-link="${id}" aria-label="Remove this link">Remove</button>
        <label class="editor-field-label mono">Type</label>
        <select class="editor-input contact-link-type" data-link-field="${id}.type">
          <option value="email">Email</option>
          <option value="linkedin">LinkedIn</option>
          <option value="github">GitHub</option>
          <option value="other" selected>Other</option>
        </select>
        <label class="editor-field-label mono">Label</label>
        <input class="editor-input contact-link-label" type="text" placeholder="e.g. Twitter, Calendly" value="" data-link-field="${id}.label" />
        <label class="editor-field-label mono">Value</label>
        <input class="editor-input contact-link-value" type="text" placeholder="https://..." value="" data-link-field="${id}.value" />
        <p class="contact-link-hint" data-link-hint="${id}" hidden>Finish the URL (or email) to save this link — it won't be lost, just held until it's complete.</p>
      `;
      list.appendChild(row);
      wireRow(row);
      void autosaver.flush(); // add-link click — discrete commit

      const typeEl = row.querySelector<HTMLSelectElement>('.contact-link-type');
      typeEl?.focus();
    });

    window.addEventListener('editor:save-all', () => {
      void autosaver.flush();
    });
  }

  // --- Empty-state message (product-owner-20260717T200000 Decision 3) ---
  const emptyStateEl = document.getElementById('empty-state-text') as HTMLInputElement | null;
  if (emptyStateEl) {
    const seedEmptyStates = (
      window as unknown as { __editorSeed: { emptyStates: { projects: string; experience: string; blog: string; contact: string } } }
    ).__editorSeed.emptyStates;
    const workingEmptyStates = { ...seedEmptyStates };

    const emptyStatesAutosaver = makeAutosaver({
      save: () => saveArea('emptyStates', workingEmptyStates),
    });

    emptyStateEl.addEventListener('input', () => {
      workingEmptyStates.contact = emptyStateEl.value;
      emptyStatesAutosaver.markDirty();
    });

    wireField({
      id: 'contact:emptyState',
      el: emptyStateEl,
      getValue: () => emptyStateEl.value,
      setValue: (value) => {
        emptyStateEl.value = value;
      },
      onApply: (value) => {
        workingEmptyStates.contact = value;
        void emptyStatesAutosaver.flush(); // undo/redo apply
      },
    });

    // commit(historyId) (wireField's own blur listener above) runs first;
    // this second blur listener (registered after) fires next.
    emptyStateEl.addEventListener('blur', () => {
      void emptyStatesAutosaver.flush();
    });

    window.addEventListener('editor:save-all', () => {
      void emptyStatesAutosaver.flush();
    });
  }
</script>

<style>
  h1 {
    font-size: 2rem;
    margin: 0 0 0.75rem;
  }

  .lede {
    color: #c9ccd9;
    font-size: 1.05rem;
    margin: 0 0 2.5rem;
  }

  .editor-note {
    max-width: 65ch;
    font-size: 0.85rem;
    color: #8891ab;
  }

  .contact-links-list { display: flex; flex-direction: column; gap: 1rem; margin: 0.5rem 0 1rem; }
  .contact-link-row {
    position: relative;
    display: grid;
    grid-template-columns: 8rem 1fr 1fr;
    gap: 0.75rem 1rem;
    align-items: end;
    border: 1px solid var(--line, #d8d3c7);
    border-radius: 4px;
    padding: 1rem 3.5rem 1rem 1rem;
    background: rgba(245, 243, 238, 0.04);
  }
  .contact-link-row .editor-field-label { margin: 0 0 0.3rem; font-size: 0.7rem; }
  .contact-link-row .editor-input { max-width: none; width: 100%; }
  .contact-link-row .editor-input:disabled { opacity: 0.45; cursor: not-allowed; }
  .contact-link-remove { position: absolute; top: 0.75rem; right: 0.75rem; }
  .contact-link-hint {
    grid-column: 1 / -1;
    margin: -0.3rem 0 0;
    font-size: 0.72rem;
    color: var(--signal-text, #c87f0a);
  }

  @media (max-width: 640px) {
    .contact-link-row { grid-template-columns: 1fr; padding-top: 2.75rem; }
  }
</style>
