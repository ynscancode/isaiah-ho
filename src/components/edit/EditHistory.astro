---
import Band from '../Band.astro';
---

<Band variant="ink" eyebrow="06 — History" as="div">
  <h1>Version history</h1>
  <p id="history-status" role="status" aria-live="polite"></p>

  <p class="editor-note" id="history-loading">Loading history…</p>
  <p class="editor-note" id="history-empty" hidden>
    No saved versions yet — history will appear here once you save a change.
  </p>
  <div id="history-error-banner" class="editor-toolbar-banner" role="alert" hidden>
    Couldn't load version history. <a href="#" id="history-retry">Retry</a>
  </div>

  <ul class="history-list" id="history-list" aria-label="Version history" hidden></ul>
</Band>

<script>
  import { fetchHistory, revertDraft } from '../../lib/editor/client';
  import type { CommitSummary, HistorySession } from '../../lib/editor/client';

  const SITE_JSON_AREAS = new Set(['home', 'about', 'contact', 'emptyStates']);

  type ParsedCommit =
    | { kind: 'update-site'; area: string }
    | { kind: 'update-isolated'; area: 'projects' | 'experience' }
    | { kind: 'update-blog'; slug: string }
    | { kind: 'delete-blog'; slug: string }
    | { kind: 'other' };

  // Message prefixes actually emitted by the server (senior-backend-dev
  // -20260718T082840 / src/pages/api/content/[area].ts + api/draft/revert.ts):
  //   Normal saves: "Update <home|about|contact|emptyStates> content" (all
  //     four bundled in site.json — any one of them touches the same file),
  //     "Update <projects|experience> content", "Update blog post: <slug>",
  //     "Delete blog post: <slug>".
  //   Reverts: "Revert site content to <shortSha>" (site.json — always
  //     labeled "site", not the originating area, since a revert restores
  //     the whole bundled file), "Revert <projects|experience> content to
  //     <shortSha>", "Revert blog post <slug> to <shortSha>".
  function parseCommit(message: string): ParsedCommit {
    let m = message.match(/^Update (home|about|contact|emptyStates) content$/);
    if (m) return { kind: 'update-site', area: m[1] };
    if (message.match(/^Revert site content to [0-9a-f]+$/)) return { kind: 'update-site', area: 'site' };
    m = message.match(/^(?:Update|Revert) (projects|experience) content(?: to [0-9a-f]+)?$/);
    if (m) return { kind: 'update-isolated', area: m[1] as 'projects' | 'experience' };
    m = message.match(/^Update blog post: (.+)$/);
    if (m) return { kind: 'update-blog', slug: m[1] };
    m = message.match(/^Revert blog post (.+) to [0-9a-f]+$/);
    if (m) return { kind: 'update-blog', slug: m[1] };
    m = message.match(/^Delete blog post: (.+)$/);
    if (m) return { kind: 'delete-blog', slug: m[1] };
    return { kind: 'other' };
  }

  function areaBadge(parsed: ParsedCommit): string {
    switch (parsed.kind) {
      case 'update-site':
        return parsed.area;
      case 'update-isolated':
        return parsed.area;
      case 'update-blog':
      case 'delete-blog':
        return 'blog';
      default:
        return 'other';
    }
  }

  // Human-readable area names for the collapsed-card single-line summary
  // (ui-ux-designer-20260719T104512 §1). Cosmetic only — never used for any
  // trust/security decision; the sha sent to revertDraft is derived
  // independently (see handleRestore call sites).
  const AREA_LABELS: Record<string, string> = {
    home: 'Home',
    about: 'About',
    contact: 'Contact',
    emptyStates: 'Empty states',
    site: 'Site content',
    projects: 'Projects',
    experience: 'Experience',
    blog: 'Blog',
    sync: 'Sync',
  };
  const GENERIC_AREA_LABEL = 'content';
  function friendlyArea(code: string): string {
    return AREA_LABELS[code] ?? GENERIC_AREA_LABEL;
  }

  /** Single-line summary for a single-commit "session" (today's plain row) —
   * derived from the already-parsed commit, never the raw message (that raw
   * fallback was the overflow bug). ui-ux-designer-20260719T104512 §1(c)/(d). */
  function summarizeCommit(parsed: ParsedCommit, rawMessage: string): string {
    switch (parsed.kind) {
      case 'update-site':
      case 'update-isolated':
        return `Edited ${friendlyArea(parsed.area)}`;
      case 'update-blog':
        return 'Edited Blog';
      case 'delete-blog':
        return 'Deleted blog post';
      case 'other':
        if (/^Sync master into editor-draft$/.test(rawMessage.split('\n')[0].trim())) {
          return 'Synced from live site';
        }
        return 'Edited content';
    }
  }

  /** Single-line summary for a collapsed multi-commit session card, built
   * from `session.areas` (already distinct, newest-first) mapped through
   * `friendlyArea` and re-deduped. ui-ux-designer-20260719T104512 §1(a)/(b). */
  function summarizeSession(session: HistorySession): string {
    const names: string[] = [];
    session.areas.forEach((code) => {
      const label = friendlyArea(code);
      if (!names.includes(label)) names.push(label);
    });
    if (names.length <= 1) {
      return `Edited ${names[0] ?? GENERIC_AREA_LABEL}`;
    }
    if (names.length === 2) {
      return `Edited ${names[0]} & ${names[1]}`;
    }
    if (names.length === 3) {
      return `Edited ${names[0]}, ${names[1]} & ${names[2]}`;
    }
    const more = names.length - 2;
    return `Edited ${names[0]}, ${names[1]} & ${more} more`;
  }

  function confirmCopy(parsed: ParsedCommit, timestamp: string): string {
    switch (parsed.kind) {
      case 'update-site':
        return `Restore "${parsed.area}" to its state as of ${timestamp}? Because home, about, contact, and the empty-state messages are all saved together, this will roll ALL FOUR back to that same moment — not just ${parsed.area}. This creates a new save; it doesn't lose history and can be reverted again.`;
      case 'update-isolated':
        return `Restore "${parsed.area}" to its state as of ${timestamp}? This creates a new save; it doesn't lose history and can be reverted again.`;
      case 'update-blog':
        return `Restore "${parsed.slug}" to its state as of ${timestamp}? This creates a new save; it doesn't lose history and can be reverted again.`;
      case 'delete-blog':
        return `Un-delete "${parsed.slug}" and restore it to its state as of ${timestamp}? This creates a new save; it doesn't lose history and can be reverted again.`;
      default:
        return `Restore this version to its state as of ${timestamp}? This creates a new save; it doesn't lose history and can be reverted again.`;
    }
  }

  function formatRelative(date: Date): string {
    const diffMs = Date.now() - date.getTime();
    const diffSec = Math.round(diffMs / 1000);
    if (diffSec < 60) return 'Just now';
    const diffMin = Math.round(diffSec / 60);
    if (diffMin < 60) return `${diffMin} minute${diffMin === 1 ? '' : 's'} ago`;
    const diffHr = Math.round(diffMin / 60);
    if (diffHr < 24) return `${diffHr} hour${diffHr === 1 ? '' : 's'} ago`;
    const diffDay = Math.round(diffHr / 24);
    if (diffDay < 30) return `${diffDay} day${diffDay === 1 ? '' : 's'} ago`;
    return date.toLocaleDateString();
  }

  /** Locked absolute timestamp format (engineering-director-20260719T103859):
   * built from LOCAL Date parts via toLocaleString/Intl options — NEVER
   * toISOString()/UTC slicing (KB-0003). */
  function formatAbsolute(date: Date): string {
    return date.toLocaleString(undefined, {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
      hour: 'numeric',
      minute: '2-digit',
    });
  }

  /** Locked combined timestamp label: "{absolute} · {relative}", e.g.
   * "Jul 19, 2026, 6:24 PM · 2 hours ago" (engineering-director
   * -20260719T103859, ui-ux-designer-20260719T104512 §2). */
  function formatTimeLabel(date: Date): string {
    return `${formatAbsolute(date)} · ${formatRelative(date)}`;
  }

  const statusEl = document.getElementById('history-status');
  const loadingEl = document.getElementById('history-loading');
  const emptyEl = document.getElementById('history-empty');
  const errorBanner = document.getElementById('history-error-banner');
  const retryLink = document.getElementById('history-retry');
  const listEl = document.getElementById('history-list') as HTMLUListElement | null;

  function setStatus(text: string, tone?: 'error') {
    if (!statusEl) return;
    statusEl.textContent = text;
    if (tone) statusEl.setAttribute('data-tone', tone);
    else statusEl.removeAttribute('data-tone');
  }

  function focusStatus() {
    if (!statusEl) return;
    statusEl.setAttribute('tabindex', '-1');
    statusEl.focus();
  }

  function setRestoreButtonsDisabled(disabled: boolean) {
    listEl?.querySelectorAll<HTMLButtonElement>('[data-restore-sha]').forEach((btn) => {
      btn.disabled = disabled;
    });
  }

  /** Session-level restore confirm copy (tech-lead-20260719T095958 Issue 3 —
   * "Restore this version" targets the session's FINAL commit, `latestSha`).
   * Reuses the same per-kind area wording as `confirmCopy` but makes clear
   * this rolls forward the whole session, not just its last edit. */
  function sessionConfirmCopy(parsed: ParsedCommit, timestamp: string, commitCount: number): string {
    const sessionNote = ` This version included ${commitCount} autosaved edits — restoring rolls everything in it forward to its final saved state as of ${timestamp}, not just the last change.`;
    switch (parsed.kind) {
      case 'update-site':
        return `Restore this version, dated ${timestamp}? Because home, about, contact, and the empty-state messages are all saved together, this will roll ALL FOUR back to that same moment — not just "${parsed.area}".${sessionNote} This creates a new save; it doesn't lose history and can be reverted again.`;
      case 'update-isolated':
        return `Restore this version of "${parsed.area}", dated ${timestamp}?${sessionNote} This creates a new save; it doesn't lose history and can be reverted again.`;
      case 'update-blog':
        return `Restore this version of "${parsed.slug}", dated ${timestamp}?${sessionNote} This creates a new save; it doesn't lose history and can be reverted again.`;
      case 'delete-blog':
        return `Un-delete "${parsed.slug}" and restore this version, dated ${timestamp}?${sessionNote} This creates a new save; it doesn't lose history and can be reverted again.`;
      default:
        return `Restore this version, dated ${timestamp}?${sessionNote} This creates a new save; it doesn't lose history and can be reverted again.`;
    }
  }

  /** Renders one member commit — used both for a single-commit session's
   * plain row (restoreLabel: 'Restore this version', identical to today's
   * flat-list row) and for a member inside an expanded multi-commit session
   * (restoreLabel: 'Restore this edit'). The very newest commit overall
   * (`isHead`) always shows "Current" and no restore button. */
  function renderMemberRow(
    commit: CommitSummary,
    isHead: boolean,
    restoreLabel: 'Restore this version' | 'Restore this edit',
    displayText: string = commit.message.split('\n')[0].trim()
  ): HTMLLIElement {
    const parsed = parseCommit(commit.message);
    const date = new Date(commit.date);
    const li = document.createElement('li');
    li.className = isHead ? 'history-row history-row--current' : 'history-row';

    const badge = document.createElement('span');
    badge.className = 'history-area-badge';
    badge.textContent = areaBadge(parsed);
    li.appendChild(badge);

    const msg = document.createElement('span');
    msg.className = 'history-row-message';
    msg.textContent = displayText;
    li.appendChild(msg);

    const time = document.createElement('time');
    time.className = 'history-row-time';
    time.setAttribute('datetime', commit.date);
    time.textContent = formatTimeLabel(date);
    li.appendChild(time);

    if (isHead) {
      const current = document.createElement('span');
      current.className = 'history-row-current-label mono';
      current.textContent = 'Current';
      li.appendChild(current);
    } else {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'editor-btn';
      btn.textContent = restoreLabel;
      btn.setAttribute('data-restore-sha', commit.sha);
      btn.setAttribute(
        'aria-label',
        `${restoreLabel}: ${commit.message}, ${formatRelative(date)}`
      );
      btn.addEventListener('click', () => {
        void handleRestore(commit.sha, confirmCopy(parsed, date.toLocaleString()), btn);
      });
      li.appendChild(btn);
    }

    return li;
  }

  /** Renders a collapsed, expandable session card for a multi-commit
   * session. Disclosure toggle is a real <button> with aria-expanded /
   * aria-controls (keyboard-operable). Expanding reveals member commits
   * newest-first via renderMemberRow. The card-level "Restore this version"
   * button always targets `session.latestSha` (director decision #2). */
  function renderSessionCard(session: HistorySession, isCurrentSession: boolean): HTMLLIElement {
    const li = document.createElement('li');
    li.className = isCurrentSession ? 'history-session history-session--current' : 'history-session';

    const summary = document.createElement('div');
    summary.className = 'history-session-summary';

    const membersId = `history-session-members-${session.latestSha}`;

    const toggle = document.createElement('button');
    toggle.type = 'button';
    toggle.className = 'history-session-toggle';
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-controls', membersId);

    const summaryText = summarizeSession(session);

    const summaryTextEl = document.createElement('span');
    summaryTextEl.className = 'history-session-summary-text';
    summaryTextEl.textContent = summaryText;
    toggle.appendChild(summaryTextEl);

    const endedDate = new Date(session.endedAt);
    const time = document.createElement('time');
    time.className = 'history-row-time';
    time.setAttribute('datetime', session.endedAt);
    time.textContent = formatTimeLabel(endedDate);
    toggle.appendChild(time);

    const countLabel = document.createElement('span');
    countLabel.className = 'history-session-count';
    countLabel.textContent = `${session.commitCount} edits`;
    toggle.appendChild(countLabel);

    if (isCurrentSession) {
      const current = document.createElement('span');
      current.className = 'history-row-current-label mono';
      current.textContent = 'Current';
      toggle.appendChild(current);
    }

    const chevron = document.createElement('span');
    chevron.className = 'history-session-chevron';
    chevron.setAttribute('aria-hidden', 'true');
    chevron.textContent = '▾';
    toggle.appendChild(chevron);

    toggle.setAttribute(
      'aria-label',
      `${summaryText}, ${formatTimeLabel(endedDate)}, ${session.commitCount} edits. Expand to see individual edits.`
    );

    summary.appendChild(toggle);

    const latest = session.commits[0];
    const parsedLatest = parseCommit(latest.message);

    const restoreBtn = document.createElement('button');
    restoreBtn.type = 'button';
    restoreBtn.className = 'editor-btn';
    restoreBtn.textContent = 'Restore this version';
    restoreBtn.setAttribute('data-restore-sha', session.latestSha);
    restoreBtn.setAttribute(
      'aria-label',
      `Restore this version: ${summaryText}, ${formatTimeLabel(endedDate)}`
    );
    restoreBtn.addEventListener('click', () => {
      void handleRestore(
        session.latestSha,
        sessionConfirmCopy(parsedLatest, endedDate.toLocaleString(), session.commitCount),
        restoreBtn
      );
    });
    summary.appendChild(restoreBtn);

    li.appendChild(summary);

    const membersList = document.createElement('ul');
    membersList.id = membersId;
    membersList.className = 'history-session-members';
    membersList.hidden = true;
    session.commits.forEach((commit, idx) => {
      const isHeadCommit = isCurrentSession && idx === 0;
      membersList.appendChild(renderMemberRow(commit, isHeadCommit, 'Restore this edit'));
    });
    li.appendChild(membersList);

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      membersList.hidden = expanded;
    });

    return li;
  }

  function renderSession(session: HistorySession, isCurrentSession: boolean): HTMLLIElement {
    if (session.commitCount <= 1) {
      // Single-commit session: plain non-expandable row (director decision
      // #3), now with the same short summary + locked timestamp treatment
      // as a session card (ui-ux-designer-20260719T104512 §4).
      const commit = session.commits[0];
      const displayText = summarizeCommit(parseCommit(commit.message), commit.message);
      return renderMemberRow(session.commits[0], isCurrentSession, 'Restore this version', displayText);
    }
    return renderSessionCard(session, isCurrentSession);
  }

  async function handleRestore(targetSha: string, confirmMessage: string, btn: HTMLButtonElement) {
    const confirmed = window.confirm(confirmMessage);
    if (!confirmed) return;

    setRestoreButtonsDisabled(true);
    const originalLabel = btn.textContent;
    btn.textContent = 'Restoring…';
    setStatus('Restoring…');

    const result = await revertDraft(targetSha);

    if (result.ok) {
      setStatus('Restored. Reload to see the update everywhere in the editor.');
      focusStatus();
      appendReloadControl();
      await loadHistory();
    } else {
      setStatus(`Restore failed: ${result.error}. Try again.`, 'error');
      focusStatus();
      setRestoreButtonsDisabled(false);
      btn.textContent = originalLabel;
    }
  }

  function appendReloadControl() {
    if (!statusEl || document.getElementById('history-reload-btn')) return;
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.id = 'history-reload-btn';
    btn.className = 'editor-btn';
    btn.textContent = 'Reload';
    btn.addEventListener('click', () => location.reload());
    statusEl.appendChild(document.createTextNode(' '));
    statusEl.appendChild(btn);
  }

  async function loadHistory() {
    loadingEl?.removeAttribute('hidden');
    emptyEl?.setAttribute('hidden', '');
    errorBanner?.setAttribute('hidden', '');
    listEl?.setAttribute('hidden', '');

    const result = await fetchHistory();

    loadingEl?.setAttribute('hidden', '');

    if (!result) {
      errorBanner?.removeAttribute('hidden');
      return;
    }

    const sessions = result.sessions ?? [];
    if (sessions.length === 0) {
      emptyEl?.removeAttribute('hidden');
      return;
    }

    if (listEl) {
      listEl.innerHTML = '';
      sessions.forEach((session, index) => {
        listEl.appendChild(renderSession(session, index === 0));
      });
      listEl.removeAttribute('hidden');
    }
  }

  retryLink?.addEventListener('click', (event) => {
    event.preventDefault();
    void loadHistory();
  });

  void loadHistory();
</script>

<style>
  h1 {
    font-size: 2rem;
    margin: 0 0 2rem;
  }

  #history-status {
    min-height: 1.2rem;
    font-size: 0.85rem;
    margin: 0 0 1rem;
  }
  #history-status[data-tone="error"] {
    color: #ff9c9c;
  }

  .editor-note {
    max-width: 65ch;
    font-size: 0.85rem;
    color: #8891ab;
  }

  .history-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
    list-style: none;
    padding: 0;
  }
</style>

<style is:global>
  .history-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.85rem 1rem;
    border: 1px solid #3a4468;
    border-radius: 4px;
    background: rgba(245, 243, 238, 0.04);
  }
  .history-row--current {
    border-color: var(--signal, #c87f0a);
  }
  .history-row-message {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.85rem;
  }
  .history-row-time {
    flex: 0 0 auto;
    font-size: 0.78rem;
    opacity: 0.75;
    white-space: nowrap;
  }
  .history-area-badge {
    flex: 0 0 auto;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border: 1px solid currentColor;
    border-radius: 2px;
    opacity: 0.85;
  }
  .history-row-current-label {
    flex: 0 0 auto;
    font-size: 0.75rem;
    color: var(--signal, #c87f0a);
    opacity: 0.9;
  }

  .history-session {
    border: 1px solid #3a4468;
    border-radius: 4px;
    background: rgba(245, 243, 238, 0.04);
    overflow: hidden;
  }
  .history-session--current {
    border-color: var(--signal, #c87f0a);
  }
  .history-session-summary {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 0.85rem 1rem;
  }
  .history-session-toggle {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    flex: 1 1 auto;
    min-width: 220px;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    color: inherit;
    font: inherit;
    text-align: left;
    cursor: pointer;
  }
  .history-session-toggle:focus-visible {
    outline: 2px solid var(--signal, #c87f0a);
    outline-offset: 2px;
  }
  .history-session-summary-text {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.85rem;
  }
  .history-session-count {
    flex: 0 0 auto;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.78rem;
    opacity: 0.75;
    white-space: nowrap;
  }
  .history-session-chevron {
    flex: 0 0 auto;
    margin-left: auto;
    transition: transform 0.15s ease;
  }
  .history-session-toggle[aria-expanded="true"] .history-session-chevron {
    transform: rotate(-180deg);
  }
  .history-session-members {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: none;
    margin: 0;
    padding: 0.75rem 1rem 1rem;
    border-top: 1px solid #3a4468;
  }
  .history-session-members[hidden] {
    display: none;
  }
  .history-session-members .history-row {
    background: rgba(245, 243, 238, 0.02);
  }
</style>
