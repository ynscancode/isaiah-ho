---
import Band from '../Band.astro';

export type BlogPostData = {
  slug: string;
  title: string;
  description: string;
  date: string; // yyyy-mm-dd, for <input type="date">
  draft: boolean;
  tags: string[];
  body: string;
};

export type Props = {
  post: BlogPostData;
  isNew: boolean;
};

const { post, isNew } = Astro.props;
---

<Band variant="paper" as="div">
  <a class="back-link" href="/edit/blog">&larr; Back to blog list</a>
  <h1>{isNew ? 'New blog post' : `Editing: ${post.title}`}</h1>

  <div data-editable-area="blog" data-is-new={isNew ? 'true' : 'false'} data-slug={post.slug}>
    <label class="editor-field-label mono" for="post-title">Title</label>
    <input id="post-title" class="editor-input" type="text" value={post.title} data-editable="title" />

    <label class="editor-field-label mono" for="post-description">Description</label>
    <input id="post-description" class="editor-input" type="text" value={post.description} data-editable="description" />

    <div class="editor-inline-controls">
      <div>
        <label class="editor-field-label mono" for="post-date">Date</label>
        <input id="post-date" class="editor-input" type="date" value={post.date} data-editable="date" />
      </div>
      <div>
        <label class="editor-field-label mono" for="post-draft">
          <input id="post-draft" type="checkbox" checked={post.draft} data-editable="draft" /> Draft (unpublished)
        </label>
      </div>
    </div>

    <label class="editor-field-label mono" for="post-tags">Tags (comma-separated)</label>
    <input id="post-tags" class="editor-input" type="text" value={post.tags.join(', ')} data-editable="tags" />

    <label class="editor-field-label mono" for="post-body">Body</label>
    <textarea id="post-body" class="editor-textarea" data-editable="body">{post.body}</textarea>
    <p class="editor-note">
      Line breaks and blank lines are preserved as written — no special formatting needed.
    </p>

    {!isNew && (
      <p class="editor-note">
        Slug <code>{post.slug}</code> is fixed — editing the title does not change the post's URL.
      </p>
    )}
    {isNew && (
      <p class="editor-note">
        The URL slug is generated from the title the first time you save, then stays fixed.
      </p>
    )}
  </div>
</Band>

<script define:vars={{ post, isNew }}>
  window.__editorSeed = window.__editorSeed || {};
  window.__editorSeed.blogPost = { post, isNew };
</script>

<script>
  import { makeAutosaver, saveArea, slugify } from '../../lib/editor/client';
  import type { SaveResult } from '../../lib/editor/client';
  import type { BlogPostData } from './EditBlogPost.astro';
  import { wireField } from '../../lib/editor/history';

  const container = document.querySelector<HTMLElement>('[data-editable-area="blog"]');
  if (container) {
    const seed = (window as unknown as { __editorSeed: { blogPost: { post: BlogPostData; isNew: boolean } } })
      .__editorSeed.blogPost;

    let working: BlogPostData = { ...seed.post };
    let isNew = seed.isNew;
    let slugLocked = !isNew;
    // The slug this post is addressed by. Undefined only until the first
    // successful save of a brand-new post; after that (whether this session
    // started as new-and-just-created, or was an edit from the start) it's
    // fixed to the persisted slug and only ever reassigned to keep tracking
    // that same value post-save, never to a user-edited one. Sent as
    // `originalSlug` on every save once known, so the server can reject a
    // slug change instead of silently creating an orphaned file (see
    // src/pages/api/content/[area].ts trust-boundary check).
    let originalSlug: string | undefined = isNew ? undefined : seed.post.slug;

    async function saveBlogPost(): Promise<SaveResult> {
      if (!working.title.trim()) {
        // Client-side guard only — never sent to the server. Treated as a
        // generic failure by the autosaver: status -> 'error', area stays
        // dirty, next edit/save retries once there's a title to send.
        return { ok: false, error: 'missing_title' };
      }
      if (!slugLocked) {
        working.slug = slugify(working.title);
      }
      const payload = originalSlug !== undefined ? { ...working, originalSlug } : working;
      const result = await saveArea('blog', payload);
      if (result.ok) {
        slugLocked = true;
        originalSlug = working.slug;
        if (isNew) {
          isNew = false;
          // Adopt the now-fixed URL so a page refresh / bookmark points at
          // the real post instead of /edit/blog/new.
          window.history.replaceState(null, '', `/edit/blog/${working.slug}`);
        }
      }
      return result;
    }

    const autosaver = makeAutosaver({ save: saveBlogPost });

    const titleEl = document.getElementById('post-title') as HTMLInputElement;
    const descEl = document.getElementById('post-description') as HTMLInputElement;
    const dateEl = document.getElementById('post-date') as HTMLInputElement;
    const draftEl = document.getElementById('post-draft') as HTMLInputElement;
    const tagsEl = document.getElementById('post-tags') as HTMLInputElement;
    const bodyEl = document.getElementById('post-body') as HTMLTextAreaElement;

    titleEl.addEventListener('input', () => {
      working.title = titleEl.value;
      autosaver.markDirty();
    });
    descEl.addEventListener('input', () => {
      working.description = descEl.value;
      autosaver.markDirty();
    });
    dateEl.addEventListener('input', () => {
      working.date = dateEl.value;
      autosaver.markDirty();
    });
    draftEl.addEventListener('change', () => {
      working.draft = draftEl.checked;
      void autosaver.flush(); // checkbox toggle — discrete commit, like a <select> change
    });
    tagsEl.addEventListener('input', () => {
      working.tags = tagsEl.value
        .split(',')
        .map((tag) => tag.trim())
        .filter((tag) => tag.length > 0);
      autosaver.markDirty();
    });
    bodyEl.addEventListener('input', () => {
      working.body = bodyEl.value;
      autosaver.markDirty();
    });

    // Item 5: per-field undo/redo, committed at each field's own blur
    // boundary (matches PO's field-commit-boundary granularity).
    wireField({
      id: 'blog:title',
      el: titleEl,
      getValue: () => titleEl.value,
      setValue: (v) => { titleEl.value = v; },
      onApply: (v) => { working.title = v; void autosaver.flush(); },
    });
    wireField({
      id: 'blog:description',
      el: descEl,
      getValue: () => descEl.value,
      setValue: (v) => { descEl.value = v; },
      onApply: (v) => { working.description = v; void autosaver.flush(); },
    });
    wireField({
      id: 'blog:date',
      el: dateEl,
      getValue: () => dateEl.value,
      setValue: (v) => { dateEl.value = v; },
      onApply: (v) => { working.date = v; void autosaver.flush(); },
    });
    wireField({
      id: 'blog:tags',
      el: tagsEl,
      getValue: () => tagsEl.value,
      setValue: (v) => { tagsEl.value = v; },
      onApply: (v) => {
        working.tags = v.split(',').map((tag) => tag.trim()).filter((tag) => tag.length > 0);
        void autosaver.flush();
      },
    });
    wireField({
      id: 'blog:body',
      el: bodyEl,
      getValue: () => bodyEl.value,
      setValue: (v) => { bodyEl.value = v; },
      onApply: (v) => { working.body = v; void autosaver.flush(); },
    });

    // commit(historyId) (each field's own blur-triggered undo-step boundary,
    // registered by wireField above) must run before flush() — adding these
    // listeners AFTER the wireField() calls guarantees DOM listener order
    // fires commit first, then the git-commit flush.
    for (const el of [titleEl, descEl, dateEl, tagsEl, bodyEl]) {
      el.addEventListener('blur', () => {
        void autosaver.flushIfDirty();
      });
    }

    window.addEventListener('editor:save-all', () => {
      void autosaver.flush();
    });
  }
</script>

<style>
  h1 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin: 0.5rem 0 1.5rem;
  }

  .back-link {
    display: inline-block;
    color: var(--signal-text);
    text-decoration: none;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.9rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .editor-note {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--slate);
  }

  .editor-note code {
    font-family: "IBM Plex Mono", monospace;
  }
</style>
