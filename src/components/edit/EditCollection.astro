---
import Band from '../Band.astro';
import Card from '../Card.astro';

export type CollectionEntry = {
  id: string;
  slug: string;
  category: string;
  startDate: string | null;
  endDate: string | null;
  title: string;
  body: string;
  href?: string;
  detail?: string;
};

export type Props = {
  area: 'projects' | 'experience';
  eyebrow: string;
  entries: CollectionEntry[];
  emptyStates: { projects: string; experience: string; blog: string; contact: string };
};

const { area, eyebrow, entries, emptyStates } = Astro.props;
const heading = area === 'projects' ? 'Projects' : 'Experience';
---

<Band variant="paper" eyebrow={eyebrow} as="div">
  <h1>{heading}</h1>
  <div class="cards" data-editable-area={area} data-collection-list>
    {entries.map((entry) => (
      <div class="card-slot" data-entry-id={entry.id}>
        <Card
          category={entry.category}
          startDate={entry.startDate}
          endDate={entry.endDate}
          title={entry.title}
          body={entry.body}
          href={entry.href}
          detail={entry.detail}
          editable
          editablePrefix={entry.id}
          removable
        />
      </div>
    ))}
  </div>
  <button type="button" class="editor-add-btn" id={`add-${area}-entry`}>+ Add {area === 'projects' ? 'project' : 'entry'}</button>

  <template id={`tpl-${area}-card`}>
    <div class="card-slot" data-entry-id="__ID__">
      <Card
        category=""
        startDate={null}
        endDate={null}
        title=""
        body=""
        editable
        editablePrefix="__ID__"
        removable
      />
    </div>
  </template>

  <hr class="editor-divider" />
  <label class="editor-field-label mono" for={`empty-state-text-${area}`}>Empty-state message</label>
  <input id={`empty-state-text-${area}`} class="editor-input" type="text" value={emptyStates[area]} data-editable="emptyState" />
  <p class="editor-note">Shown on the public page in place of the list when this section has zero entries.</p>
</Band>

<script define:vars={{ area, entries, emptyStates }}>
  // define:vars serializes `entries`/`area`/`emptyStates` into this inline
  // script — used only as the initial seed for the in-memory working state,
  // never rendered back into the DOM as raw HTML.
  window.__editorSeed = window.__editorSeed || {};
  window.__editorSeed[area] = entries;
  window.__editorSeed.emptyStates = emptyStates;
</script>

<script>
  import { makeAutosaver, saveArea, slugify, uniqueId } from '../../lib/editor/client';
  import { commitAtomic, register, unregister, wireField } from '../../lib/editor/history';

  type Entry = {
    id: string;
    slug: string;
    category: string;
    startDate: string | null;
    endDate: string | null;
    title: string;
    body: string;
    href?: string;
    detail?: string;
  };

  const list = document.querySelector<HTMLElement>('[data-collection-list]');
  const areaAttr = list?.getAttribute('data-editable-area');
  const area = areaAttr === 'projects' || areaAttr === 'experience' ? areaAttr : null;
  if (list && area) {
    // Re-bind to a narrowed const: TS doesn't retain the `area !== null`
    // narrowing for a variable captured by the nested save() closure below.
    const areaName: 'projects' | 'experience' = area;
    const seed = ((window as unknown as { __editorSeed: Record<string, Entry[]> }).__editorSeed?.[areaName] ?? []) as Entry[];
    const working = new Map<string, Entry>(seed.map((entry) => [entry.id, { ...entry }]));

    const autosaver = makeAutosaver({
      save: () => saveArea(areaName, Array.from(working.values())),
    });

    function fieldOf(el: HTMLElement): { id: string; field: keyof Entry } | null {
      const attr = el.getAttribute('data-editable') ?? el.getAttribute('data-editable-href');
      if (!attr) return null;
      const dot = attr.indexOf('.');
      if (dot === -1) return null;
      return { id: attr.slice(0, dot), field: attr.slice(dot + 1) as keyof Entry };
    }

    function wireSlot(slot: HTMLElement) {
      const entryId = slot.getAttribute('data-entry-id');
      const historyIds: string[] = [];

      // contenteditable text fields (category/title/body)
      slot.querySelectorAll<HTMLElement>('[contenteditable="true"][data-editable]').forEach((el) => {
        el.addEventListener('input', () => {
          // Some browsers leave a stray <br> behind after a full delete,
          // which would silently defeat the :empty::before CSS hint
          // (ui-ux-designer-20260717T210000 section 6 implementation note).
          if (el.textContent === '' && el.innerHTML !== '') {
            el.innerHTML = '';
          }
          const target = fieldOf(el);
          if (!target) return;
          const entry = working.get(target.id);
          if (!entry) return;
          (entry as unknown as Record<string, unknown>)[target.field] = el.textContent ?? '';
          autosaver.markDirty();
        });

        const target = fieldOf(el);
        if (target) {
          const historyId = `${areaName}:${target.id}.${target.field}`;
          historyIds.push(historyId);
          wireField({
            id: historyId,
            el,
            getValue: () => el.textContent ?? '',
            setValue: (value) => {
              el.textContent = value;
            },
            onApply: (value) => {
              const entry = working.get(target.id);
              if (entry) (entry as unknown as Record<string, unknown>)[target.field] = value;
              void autosaver.flush(); // undo/redo apply
            },
          });
        }

        // commit(historyId) (wireField's own blur listener above) runs
        // first; this second blur listener (registered after) fires next
        // and performs the actual git-commit flush.
        el.addEventListener('blur', () => {
          void autosaver.flushIfDirty();
        });
      });

      // native date pickers (startDate/endDate)
      slot.querySelectorAll<HTMLInputElement>('input[type="date"][data-editable]').forEach((el) => {
        el.addEventListener('input', () => {
          const target = fieldOf(el);
          if (!target) return;
          const entry = working.get(target.id);
          if (!entry) return;
          (entry as unknown as Record<string, unknown>)[target.field] = el.value.length > 0 ? el.value : null;
          autosaver.markDirty();
        });

        const target = fieldOf(el);
        if (target) {
          const historyId = `${areaName}:${target.id}.${target.field}`;
          historyIds.push(historyId);
          wireField({
            id: historyId,
            el,
            getValue: () => el.value,
            setValue: (value) => {
              el.value = value;
            },
            onApply: (value) => {
              const entry = working.get(target.id);
              if (entry) (entry as unknown as Record<string, unknown>)[target.field] = value.length > 0 ? value : null;
              void autosaver.flush(); // undo/redo apply
            },
          });
        }

        // commit(historyId) (wireField's own blur listener above) runs
        // first; this second blur listener (registered after) fires next.
        el.addEventListener('blur', () => {
          void autosaver.flushIfDirty();
        });
      });

      slot.querySelectorAll<HTMLButtonElement>('[data-editable-href]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = fieldOf(btn);
          if (!target) return;
          const entry = working.get(target.id);
          if (!entry) return;
          const current = entry.href ?? '';
          const next = window.prompt('Edit link URL (leave blank for none):', current);
          if (next === null) return;
          const value = next.trim();
          entry.href = value.length > 0 ? value : undefined;
          const valueEl = slot.querySelector('[data-editable-href-value]');
          if (valueEl) valueEl.textContent = value.length > 0 ? value : '(none)';
          void autosaver.flush(); // prompt confirm — discrete commit

          const historyId = `${areaName}:${target.id}.href`;
          register({
            id: historyId,
            read: () => working.get(target.id)?.href ?? '',
            apply: (v) => {
              const e = working.get(target.id);
              if (e) e.href = v.length > 0 ? v : undefined;
              const vEl = slot.querySelector('[data-editable-href-value]');
              if (vEl) vEl.textContent = v.length > 0 ? v : '(none)';
              void autosaver.flush(); // undo/redo apply
            },
          });
          commitAtomic(historyId, current, value);
        });
      });

      const removeBtn = slot.querySelector<HTMLButtonElement>('[data-remove-entry]');
      removeBtn?.addEventListener('click', () => {
        const id = removeBtn.getAttribute('data-remove-entry');
        if (!id) return;
        if (!window.confirm('Remove this entry? It will be deleted from the draft on next save.')) return;
        working.delete(id);
        slot.remove();
        historyIds.forEach((historyId) => unregister(historyId));
        if (entryId) unregister(`${areaName}:${entryId}.href`);
        void autosaver.flush(); // deletion — discrete commit
      });
    }

    list.querySelectorAll<HTMLElement>('.card-slot').forEach(wireSlot);

    const addBtn = document.getElementById(`add-${area}-entry`);
    const template = document.getElementById(`tpl-${area}-card`) as HTMLTemplateElement | null;
    addBtn?.addEventListener('click', () => {
      if (!template) return;
      const id = uniqueId();
      const fragment = template.content.cloneNode(true) as DocumentFragment;
      const html = fragment.querySelector('.card-slot')!.outerHTML.split('__ID__').join(id);
      const wrapper = document.createElement('div');
      wrapper.innerHTML = html;
      const slot = wrapper.firstElementChild as HTMLElement;
      // `addBtn` is a sibling of `list` (the .cards grid), not a child of it —
      // append to the grid itself rather than insertBefore(addBtn).
      list.appendChild(slot);

      // Truly empty seed (product-owner-20260717T200000 Decision 4) —
      // category/title/body start as empty strings (shown via the
      // :empty::before CSS hint, never a literal placeholder string the
      // user has to delete). `slug` is not a user-facing field here, so it
      // is auto-derived from the entry id (invisible, schema-valid) rather
      // than left empty, which would fail the server's slug min-length
      // validation on save.
      const newEntry: Entry = {
        id,
        slug: slugify(`entry-${id}`),
        category: '',
        startDate: null,
        endDate: null,
        title: '',
        body: '',
        detail: '',
      };
      working.set(id, newEntry);
      wireSlot(slot);
      void autosaver.flush(); // add-entry click — discrete commit

      const categoryEl = slot.querySelector<HTMLElement>('[data-editable$=".category"]');
      categoryEl?.focus();
    });

    window.addEventListener('editor:save-all', () => {
      void autosaver.flush();
    });
  }

  // --- Empty-state message (product-owner-20260717T200000 Decision 3) ---
  if (area) {
    const areaName: 'projects' | 'experience' = area;
    const emptyStateEl = document.getElementById(`empty-state-text-${areaName}`) as HTMLInputElement | null;
    if (emptyStateEl) {
      const seedEmptyStates = (
        window as unknown as { __editorSeed: { emptyStates?: { projects: string; experience: string; blog: string; contact: string } } }
      ).__editorSeed.emptyStates ?? { projects: '', experience: '', blog: '', contact: '' };
      const workingEmptyStates = { ...seedEmptyStates };

      const emptyStatesAutosaver = makeAutosaver({
        save: () => saveArea('emptyStates', workingEmptyStates),
      });

      emptyStateEl.addEventListener('input', () => {
        workingEmptyStates[areaName] = emptyStateEl.value;
        emptyStatesAutosaver.markDirty();
      });

      wireField({
        id: `${areaName}:emptyState`,
        el: emptyStateEl,
        getValue: () => emptyStateEl.value,
        setValue: (value) => {
          emptyStateEl.value = value;
        },
        onApply: (value) => {
          workingEmptyStates[areaName] = value;
          void emptyStatesAutosaver.flush(); // undo/redo apply
        },
      });

      // commit(historyId) (wireField's own blur listener above) runs first;
      // this second blur listener (registered after) fires next.
      emptyStateEl.addEventListener('blur', () => {
        void emptyStatesAutosaver.flushIfDirty();
      });

      window.addEventListener('editor:save-all', () => {
        void emptyStatesAutosaver.flush();
      });
    }
  }
</script>

<style>
  h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem;
  }

  template {
    display: none;
  }

  .editor-note {
    max-width: 65ch;
    font-size: 0.85rem;
    color: var(--slate);
  }
</style>
