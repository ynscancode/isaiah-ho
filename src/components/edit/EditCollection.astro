---
import Band from '../Band.astro';
import Card from '../Card.astro';
import { groupByCategory } from '../../lib/experienceGroups';

export type CollectionEntry = {
  id: string;
  slug: string;
  category: string;
  startDate: string | null;
  endDate: string | null;
  title: string;
  body: string;
  href?: string;
  detail?: string;
};

export type Props = {
  area: 'projects' | 'experience';
  eyebrow: string;
  entries: CollectionEntry[];
  emptyStates: { projects: string; experience: string; blog: string; contact: string };
};

const { area, eyebrow, entries, emptyStates } = Astro.props;
const heading = area === 'projects' ? 'Projects' : 'Experience';

// tech-lead-20260720T160424Z Item 3 / ui-ux-designer-20260721T050000Z —
// experience-branch-only grouping, computed once here at server render
// ("load time") from the seed `entries` prop, NOT reactive to later
// client-side edits (a category contenteditable change re-groups only on
// the next full page load). The projects branch (area === 'projects')
// never computes groups and renders the original single flat `.cards`
// grid below, byte-identical to before this change.
const isExperience = area === 'experience';
const groups = isExperience ? groupByCategory(entries, (entry) => entry.category) : [];
const showSubheads = isExperience && groups.length > 1;
---

<Band variant="paper" eyebrow={eyebrow} as="div">
  <h1>{heading}</h1>
  {showSubheads ? (
    <div class="collection-groups" data-editable-area={area} data-collection-list>
      {groups.map((group) => (
        <div class="category-group">
          <h2 class="mono group-subhead">{group.category}</h2>
          <div class="cards">
            {group.entries.map((entry) => (
              <div class="card-slot" data-entry-id={entry.id}>
                <Card
                  category={entry.category}
                  startDate={entry.startDate}
                  endDate={entry.endDate}
                  title={entry.title}
                  body={entry.body}
                  href={entry.href}
                  detail={entry.detail}
                  editable
                  editablePrefix={entry.id}
                  removable
                />
              </div>
            ))}
          </div>
        </div>
      ))}
      {/* ui-ux-designer-20260721T050000Z Item 3.2 — trailing, unlabeled
          "pending" grid. New entries created via "+ Add" during this
          session land here (not prematurely bucketed into "Other"); the
          grouping re-reflects on the next full page load. Gets the same
          border-top divider treatment as any group boundary via
          .category-group, but no subhead text. */}
      <div class="category-group pending-group">
        <div class="cards" data-collection-sink />
      </div>
    </div>
  ) : (
    <div class="cards" data-editable-area={area} data-collection-list>
      {entries.map((entry) => (
        <div class="card-slot" data-entry-id={entry.id}>
          <Card
            category={entry.category}
            startDate={entry.startDate}
            endDate={entry.endDate}
            title={entry.title}
            body={entry.body}
            href={entry.href}
            detail={entry.detail}
            editable
            editablePrefix={entry.id}
            removable
          />
        </div>
      ))}
    </div>
  )}
  <button type="button" class="editor-add-btn" id={`add-${area}-entry`}>+ Add {area === 'projects' ? 'project' : 'entry'}</button>

  <template id={`tpl-${area}-card`}>
    <div class="card-slot" data-entry-id="__ID__">
      <Card
        category=""
        startDate={null}
        endDate={null}
        title=""
        body=""
        editable
        editablePrefix="__ID__"
        removable
      />
    </div>
  </template>

  <hr class="editor-divider" />
  <label class="editor-field-label mono" for={`empty-state-text-${area}`}>Empty-state message</label>
  <input id={`empty-state-text-${area}`} class="editor-input" type="text" value={emptyStates[area]} data-editable="emptyState" />
  <p class="editor-note">Shown on the public page in place of the list when this section has zero entries.</p>
</Band>

<script define:vars={{ area, entries, emptyStates }}>
  // define:vars serializes `entries`/`area`/`emptyStates` into this inline
  // script — used only as the initial seed for the in-memory working state,
  // never rendered back into the DOM as raw HTML.
  window.__editorSeed = window.__editorSeed || {};
  window.__editorSeed[area] = entries;
  window.__editorSeed.emptyStates = emptyStates;
</script>

<script>
  import { makeAutosaver, saveArea, slugify, uniqueId } from '../../lib/editor/client';
  import { commitAtomic, register, unregister, wireField } from '../../lib/editor/history';

  type Entry = {
    id: string;
    slug: string;
    category: string;
    startDate: string | null;
    endDate: string | null;
    title: string;
    body: string;
    href?: string;
    detail?: string;
  };

  const list = document.querySelector<HTMLElement>('[data-collection-list]');
  const areaAttr = list?.getAttribute('data-editable-area');
  const area = areaAttr === 'projects' || areaAttr === 'experience' ? areaAttr : null;
  // Ungrouped render (projects always; experience when groups.length <= 1):
  // `list` itself is the flat `.cards` grid, so it doubles as the append
  // target. Grouped experience render: `list` is the outer wrapper around
  // all `.category-group`s, and appends must land in the trailing,
  // unlabeled "pending" grid instead (ui-ux-designer-20260721T050000Z item
  // 3.2) — marked `data-collection-sink`.
  const sink = document.querySelector<HTMLElement>('[data-collection-sink]') ?? list;
  if (list && sink && area) {
    // Re-bind to a narrowed const: TS doesn't retain the `area !== null`
    // narrowing for a variable captured by the nested save() closure below.
    const areaName: 'projects' | 'experience' = area;
    // Same narrowing loss as areaName above, but for `sink` — captured by
    // the row controller's undo-of-delete restore closure (Bug 2b) below.
    const sinkEl: HTMLElement = sink;
    const seed = ((window as unknown as { __editorSeed: Record<string, Entry[]> }).__editorSeed?.[areaName] ?? []) as Entry[];
    const working = new Map<string, Entry>(seed.map((entry) => [entry.id, { ...entry }]));

    const autosaver = makeAutosaver({
      save: () => saveArea(areaName, Array.from(working.values())),
      snapshot: () => JSON.stringify(Array.from(working.values())),
    });

    function fieldOf(el: HTMLElement): { id: string; field: keyof Entry } | null {
      const attr = el.getAttribute('data-editable') ?? el.getAttribute('data-editable-href');
      if (!attr) return null;
      const dot = attr.indexOf('.');
      if (dot === -1) return null;
      return { id: attr.slice(0, dot), field: attr.slice(dot + 1) as keyof Entry };
    }

    // --- Bug 3 (senior-frontend-dev-20260721): contenteditable <-> string
    // round-trip helpers. `el.textContent` (the old read) silently drops
    // every `<br>`/`<div>` a real Enter keystroke inserts, so a typed line
    // break never reached `working`/the saved JSON. These two helpers are
    // the ONLY place that translates between the field's DOM shape and the
    // plain-text value stored in `working` — every other read/write in this
    // file goes through them instead of `.textContent`.
    //
    // readEditable: DOM -> string. Text nodes verbatim; a `<br>` becomes
    // `\n` (except a single trailing `<br>` some browsers leave behind
    // after a caret-at-end Enter/backspace, which is dropped rather than
    // producing a phantom trailing blank line); a block child (`<div>`/
    // `<p>` — what Chrome/Firefox wrap subsequent lines in after Enter)
    // starts a new line and recurses so nested text/`<br>`s inside it are
    // read the same way.
    function readEditable(el: HTMLElement): string {
      const children = Array.from(el.childNodes);
      const parts: string[] = [];
      children.forEach((node, index) => {
        if (node.nodeType === Node.TEXT_NODE) {
          parts.push(node.textContent ?? '');
          return;
        }
        if (!(node instanceof HTMLElement)) return;
        if (node.tagName === 'BR') {
          const isLoneTrailing = index === children.length - 1;
          if (!isLoneTrailing) parts.push('\n');
          return;
        }
        if (node.tagName === 'DIV' || node.tagName === 'P') {
          if (parts.length > 0) parts.push('\n');
          parts.push(readEditable(node));
          return;
        }
        parts.push(node.textContent ?? '');
      });
      return parts.join('');
    }

    // writeEditable: string -> DOM. Builds text nodes separated by real
    // `<br>` elements only — no innerHTML / set:html, so a value round-
    // tripped through undo/redo or a save/reload can never be interpreted
    // as markup (KB-0017: the sanitizer-as-affordance lesson from Bug 3's
    // sibling `bodyToHtml` applies here too — this is belt-and-suspenders
    // on the client, the server is still the real trust boundary).
    function writeEditable(el: HTMLElement, value: string): void {
      el.textContent = '';
      const lines = value.split('\n');
      lines.forEach((line, index) => {
        el.appendChild(document.createTextNode(line));
        if (index < lines.length - 1) {
          el.appendChild(document.createElement('br'));
        }
      });
    }

    // Manual caret-position text insertion for the paste handler below —
    // deliberately not `document.execCommand('insertText', ...)` (deprecated,
    // and this file already favors explicit DOM construction over browser
    // command APIs, see writeEditable above).
    function insertTextAtCaret(text: string): void {
      const selection = window.getSelection();
      if (!selection || selection.rangeCount === 0) return;
      const range = selection.getRangeAt(0);
      range.deleteContents();
      const node = document.createTextNode(text);
      range.insertNode(node);
      range.setStartAfter(node);
      range.setEndAfter(node);
      selection.removeAllRanges();
      selection.addRange(range);
    }

    const template = document.getElementById(`tpl-${area}-card`) as HTMLTemplateElement | null;

    // Bug 2b: shared "build an empty card DOM node from the <template>"
    // logic — used by both the "+ Add" handler and the row controller's
    // undo-of-delete restore path below, so the two ways a card can be
    // (re)created never drift apart.
    function buildSlotFromTemplate(id: string): HTMLElement | null {
      if (!template) return null;
      const fragment = template.content.cloneNode(true) as DocumentFragment;
      const html = fragment.querySelector('.card-slot')!.outerHTML.split('__ID__').join(id);
      const wrapper = document.createElement('div');
      wrapper.innerHTML = html;
      return wrapper.firstElementChild as HTMLElement;
    }

    // Bug 2b: populate a freshly-built (empty-field) slot's editable DOM
    // from a restored `entry` — the "+ Add" path never needs this (it seeds
    // a genuinely empty entry, product-owner-20260717T200000 Decision 4),
    // but restoring a deleted entry has real values to write back in.
    function populateSlotFields(slot: HTMLElement, entry: Entry): void {
      slot.querySelectorAll<HTMLElement>('[contenteditable="true"][data-editable]').forEach((el) => {
        const target = fieldOf(el);
        if (!target) return;
        const value = (entry as unknown as Record<string, unknown>)[target.field];
        writeEditable(el, typeof value === 'string' ? value : '');
      });
      slot.querySelectorAll<HTMLInputElement>('input[type="date"][data-editable]').forEach((el) => {
        const target = fieldOf(el);
        if (!target) return;
        const value = (entry as unknown as Record<string, unknown>)[target.field];
        el.value = typeof value === 'string' ? value : '';
      });
      const hrefValueEl = slot.querySelector('[data-editable-href-value]');
      if (hrefValueEl) hrefValueEl.textContent = entry.href && entry.href.length > 0 ? entry.href : '(none)';
    }

    function wireSlot(slot: HTMLElement) {
      const entryId = slot.getAttribute('data-entry-id');
      const historyIds: string[] = [];

      // Bug 2b: structural delete/undo controller — models "this card
      // exists in `working` and the DOM" as its own history step, distinct
      // from any single field's value, using the EXISTING commitAtomic/
      // register/undo/redo machinery (ZERO changes to history.ts's stack
      // logic). Registered on every wireSlot() call (including a restore)
      // and — unlike the field controllers below — deliberately NEVER
      // unregistered by the delete handler: history.ts already makes
      // undo/redo of an unregistered id a documented no-op, so unregistering
      // this one would make a deletion permanently un-undoable.
      if (entryId) {
        const rowId = `${areaName}:${entryId}.__row__`;
        register({
          id: rowId,
          read: () => (working.has(entryId) ? JSON.stringify(working.get(entryId)) : ''),
          apply: (value) => {
            if (value === '') {
              // Redo of a delete: remove this card the same way the real
              // delete handler below does, using the field ids THIS
              // wireSlot() call registered (closure `slot`/`historyIds`).
              working.delete(entryId);
              slot.remove();
              historyIds.forEach((historyId) => unregister(historyId));
              unregister(`${areaName}:${entryId}.href`);
              void autosaver.flush(); // undo/redo apply — short-circuits to a status refresh, no save (isApplying())
              return;
            }
            // Undo of a delete: recreate the card exactly like "+ Add"
            // does — rebuild from the <template>, populate its fields with
            // the restored entry, then wireSlot() it so its field
            // controllers (and its own row controller) are re-registered.
            const entry = JSON.parse(value) as Entry;
            working.set(entryId, entry);
            const rebuilt = buildSlotFromTemplate(entryId);
            if (!rebuilt) return;
            // Restored card lands in `sink` — same placement "+ Add" uses,
            // not its original category group (grouping is load-time only,
            // tech-lead-20260721T154444 Bug 2b note / USER DECISION 1).
            sinkEl.appendChild(rebuilt);
            populateSlotFields(rebuilt, entry);
            wireSlot(rebuilt);
            void autosaver.flush(); // undo/redo apply — short-circuits, no save (isApplying())
          },
        });
      }

      // contenteditable text fields (category/title/body/detail)
      slot.querySelectorAll<HTMLElement>('[contenteditable="true"][data-editable]').forEach((el) => {
        const target = fieldOf(el);
        // Bug-3 single-line policy: category (the inline eyebrow) and title
        // are rendered single-line (group subhead / heading) — a newline is
        // meaningless there, so Enter is suppressed and a paste's newlines
        // collapse to spaces. body/detail stay multi-line (they round-trip
        // through bodyToHtml on the public detail pages).
        const singleLine = target?.field === 'category' || target?.field === 'title';

        // Bug A fix (tech-lead-20260721T211746): server-rendered initial
        // value is a raw text node containing literal `\n` (from
        // Card.astro), which the browser visually collapses. Normalize it
        // through the same readEditable/writeEditable round-trip used at
        // runtime so load-state DOM matches edit-state DOM (real `<br>`s).
        // Guard on includes('\n') — writeEditable(el, '') would append an
        // empty text node and defeat the :empty::before placeholder for
        // empty body/detail fields.
        if (!singleLine && target) {
          const initial = readEditable(el);
          if (initial.includes('\n')) writeEditable(el, initial);
        }

        if (singleLine) {
          el.addEventListener('keydown', (event) => {
            if (event.key === 'Enter') event.preventDefault();
          });
          el.addEventListener('paste', (event) => {
            event.preventDefault();
            const text = (event.clipboardData?.getData('text/plain') ?? '').replace(/\r?\n+/g, ' ');
            insertTextAtCaret(text);
            el.dispatchEvent(new Event('input', { bubbles: true }));
          });
        }

        el.addEventListener('input', () => {
          // Some browsers leave a stray <br> behind after a full delete,
          // which would silently defeat the :empty::before CSS hint
          // (ui-ux-designer-20260717T210000 section 6 implementation note).
          if (el.textContent === '' && el.innerHTML !== '') {
            el.innerHTML = '';
          }
          if (!target) return;
          const entry = working.get(target.id);
          if (!entry) return;
          (entry as unknown as Record<string, unknown>)[target.field] = readEditable(el);
          autosaver.markDirty();
        });

        if (target) {
          const historyId = `${areaName}:${target.id}.${target.field}`;
          historyIds.push(historyId);
          wireField({
            id: historyId,
            el,
            getValue: () => readEditable(el),
            setValue: (value) => {
              writeEditable(el, value);
            },
            onApply: (value) => {
              const entry = working.get(target.id);
              if (entry) (entry as unknown as Record<string, unknown>)[target.field] = value;
              void autosaver.flush(); // undo/redo apply
            },
          });
        }

        // commit(historyId) (wireField's own blur listener above) runs
        // first; this second blur listener (registered after) fires next
        // and performs the actual git-commit flush.
        el.addEventListener('blur', () => {
          void autosaver.flushIfDirty();
        });
      });

      // native date pickers (startDate/endDate)
      slot.querySelectorAll<HTMLInputElement>('input[type="date"][data-editable]').forEach((el) => {
        el.addEventListener('input', () => {
          const target = fieldOf(el);
          if (!target) return;
          const entry = working.get(target.id);
          if (!entry) return;
          (entry as unknown as Record<string, unknown>)[target.field] = el.value.length > 0 ? el.value : null;
          autosaver.markDirty();
        });

        const target = fieldOf(el);
        if (target) {
          const historyId = `${areaName}:${target.id}.${target.field}`;
          historyIds.push(historyId);
          wireField({
            id: historyId,
            el,
            getValue: () => el.value,
            setValue: (value) => {
              el.value = value;
            },
            onApply: (value) => {
              const entry = working.get(target.id);
              if (entry) (entry as unknown as Record<string, unknown>)[target.field] = value.length > 0 ? value : null;
              void autosaver.flush(); // undo/redo apply
            },
          });
        }

        // commit(historyId) (wireField's own blur listener above) runs
        // first; this second blur listener (registered after) fires next.
        el.addEventListener('blur', () => {
          void autosaver.flushIfDirty();
        });
      });

      slot.querySelectorAll<HTMLButtonElement>('[data-editable-href]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = fieldOf(btn);
          if (!target) return;
          const entry = working.get(target.id);
          if (!entry) return;
          const current = entry.href ?? '';
          const next = window.prompt('Edit link URL (leave blank for none):', current);
          if (next === null) return;
          const value = next.trim();
          entry.href = value.length > 0 ? value : undefined;
          const valueEl = slot.querySelector('[data-editable-href-value]');
          if (valueEl) valueEl.textContent = value.length > 0 ? value : '(none)';
          void autosaver.flush(); // prompt confirm — discrete commit

          const historyId = `${areaName}:${target.id}.href`;
          register({
            id: historyId,
            read: () => working.get(target.id)?.href ?? '',
            apply: (v) => {
              const e = working.get(target.id);
              if (e) e.href = v.length > 0 ? v : undefined;
              const vEl = slot.querySelector('[data-editable-href-value]');
              if (vEl) vEl.textContent = v.length > 0 ? v : '(none)';
              void autosaver.flush(); // undo/redo apply
            },
          });
          commitAtomic(historyId, current, value);
        });
      });

      const removeBtn = slot.querySelector<HTMLButtonElement>('[data-remove-entry]');
      removeBtn?.addEventListener('click', () => {
        const id = removeBtn.getAttribute('data-remove-entry');
        if (!id) return;
        if (!window.confirm('Remove this entry? It will be deleted from the draft on next save.')) return;
        // Bug 2b: capture the pre-delete entry BEFORE removing it, so the
        // structural row controller registered above can restore it on
        // undo. Real (non-applying) delete — this is the ONLY place a
        // deletion's git-save actually happens (the discrete flush below);
        // the row controller's own apply() only ever runs during undo()/
        // redo(), which short-circuit that same flush() via isApplying().
        const serialized = JSON.stringify(working.get(id));
        working.delete(id);
        slot.remove();
        historyIds.forEach((historyId) => unregister(historyId));
        unregister(`${areaName}:${id}.href`);
        commitAtomic(`${areaName}:${id}.__row__`, serialized, '');
        void autosaver.flush(); // deletion — discrete commit
      });
    }

    list.querySelectorAll<HTMLElement>('.card-slot').forEach(wireSlot);

    const addBtn = document.getElementById(`add-${area}-entry`);
    addBtn?.addEventListener('click', () => {
      const id = uniqueId();
      const slot = buildSlotFromTemplate(id);
      if (!slot) return;
      // `addBtn` is a sibling of `list` (or, when grouped, of the outer
      // wrapper) — append to `sink` (the flat grid, or the trailing
      // "pending" grid when grouped) rather than insertBefore(addBtn).
      sink.appendChild(slot);

      // Truly empty seed (product-owner-20260717T200000 Decision 4) —
      // category/title/body start as empty strings (shown via the
      // :empty::before CSS hint, never a literal placeholder string the
      // user has to delete). `slug` is not a user-facing field here, so it
      // is auto-derived from the entry id (invisible, schema-valid) rather
      // than left empty, which would fail the server's slug min-length
      // validation on save.
      const newEntry: Entry = {
        id,
        slug: slugify(`entry-${id}`),
        category: '',
        startDate: null,
        endDate: null,
        title: '',
        body: '',
        detail: '',
      };
      working.set(id, newEntry);
      wireSlot(slot);
      void autosaver.flush(); // add-entry click — discrete commit

      const categoryEl = slot.querySelector<HTMLElement>('[data-editable$=".category"]');
      categoryEl?.focus();
    });

    window.addEventListener('editor:save-all', () => {
      void autosaver.flush();
    });
  }

  // --- Empty-state message (product-owner-20260717T200000 Decision 3) ---
  if (area) {
    const areaName: 'projects' | 'experience' = area;
    const emptyStateEl = document.getElementById(`empty-state-text-${areaName}`) as HTMLInputElement | null;
    if (emptyStateEl) {
      const seedEmptyStates = (
        window as unknown as { __editorSeed: { emptyStates?: { projects: string; experience: string; blog: string; contact: string } } }
      ).__editorSeed.emptyStates ?? { projects: '', experience: '', blog: '', contact: '' };
      const workingEmptyStates = { ...seedEmptyStates };

      const emptyStatesAutosaver = makeAutosaver({
        save: () => saveArea('emptyStates', workingEmptyStates),
        snapshot: () => JSON.stringify(workingEmptyStates),
      });

      emptyStateEl.addEventListener('input', () => {
        workingEmptyStates[areaName] = emptyStateEl.value;
        emptyStatesAutosaver.markDirty();
      });

      wireField({
        id: `${areaName}:emptyState`,
        el: emptyStateEl,
        getValue: () => emptyStateEl.value,
        setValue: (value) => {
          emptyStateEl.value = value;
        },
        onApply: (value) => {
          workingEmptyStates[areaName] = value;
          void emptyStatesAutosaver.flush(); // undo/redo apply
        },
      });

      // commit(historyId) (wireField's own blur listener above) runs first;
      // this second blur listener (registered after) fires next.
      emptyStateEl.addEventListener('blur', () => {
        void emptyStatesAutosaver.flushIfDirty();
      });

      window.addEventListener('editor:save-all', () => {
        void emptyStatesAutosaver.flush();
      });
    }
  }
</script>

<style>
  h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem;
  }

  template {
    display: none;
  }

  /* ui-ux-designer-20260721T050000Z Item 3.2 — same "group subhead"
     rhythm as experience.astro, mirrored here for the experience-branch
     editor grouping (area === 'projects' never renders .category-group,
     so this is inert/unused on that branch). Scoped to this component,
     does NOT touch the shared global .cards rule. */
  .category-group {
    margin-top: 2.5rem;
  }

  .category-group:first-of-type {
    margin-top: 2rem;
  }

  .category-group:not(:first-of-type) {
    border-top: 1px solid var(--line);
    padding-top: 2rem;
  }

  .category-group .cards {
    margin-top: 1.25rem;
  }

  .group-subhead {
    color: var(--signal-text);
    margin: 0 0 0.6rem;
  }

  .editor-note {
    max-width: 65ch;
    font-size: 0.85rem;
    color: var(--slate);
  }
</style>
