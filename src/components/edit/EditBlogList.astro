---
import Band from '../Band.astro';
import Card from '../Card.astro';

export type Props = {
  posts: { id: string; title: string; description: string; date: Date; tags: string[]; draft: boolean }[];
  emptyStates: { projects: string; experience: string; blog: string; contact: string };
};

const { posts, emptyStates } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat('en-SG', { month: 'short', year: 'numeric' });
---

<Band variant="paper" eyebrow="Latest writing" as="div">
  <h1>Blog</h1>
  <a class="editor-add-btn" href="/edit/blog/new">+ Add blog post</a>
  <div class="cards">
    {posts.length === 0 && <p class="empty-state">No posts yet — use "Add blog post" above.</p>}
    {posts.map((post) => (
      <div class="card-slot-wrap" data-post-id={post.id}>
        <Card
          eyebrow={`${dateFormatter.format(post.date).toUpperCase()}${post.draft ? ' · DRAFT' : ''}`}
          title={post.title}
          body={post.description}
          href={`/edit/blog/${post.id}`}
          tags={post.tags}
        />
        <button type="button" class="card-remove-btn" data-remove-post={post.id} aria-label={`Delete ${post.title}`}>
          Delete
        </button>
      </div>
    ))}
  </div>

  <hr class="editor-divider" />
  <label class="editor-field-label mono" for="empty-state-text-blog">Empty-state message</label>
  <input id="empty-state-text-blog" class="editor-input" type="text" value={emptyStates.blog} data-editable="emptyState" />
  <p class="editor-note">Shown on the public page in place of the list when this section has zero entries.</p>
</Band>

<script define:vars={{ emptyStates }}>
  window.__editorSeed = window.__editorSeed || {};
  window.__editorSeed.emptyStates = emptyStates;
</script>

<script>
  import { deleteBlogPost, makeAutosaver, saveArea } from '../../lib/editor/client';

  document.querySelectorAll<HTMLButtonElement>('[data-remove-post]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-remove-post');
      if (!id) return;
      if (!window.confirm(`Delete blog post "${id}"? This removes the file from the draft branch.`)) return;
      btn.disabled = true;
      btn.textContent = 'Deleting…';
      const result = await deleteBlogPost(id);
      if (result.ok) {
        btn.closest('.card-slot-wrap')?.remove();
      } else {
        btn.disabled = false;
        btn.textContent = 'Delete';
        window.alert(`Delete failed: ${result.error ?? 'unknown error'}`);
      }
    });
  });

  // --- Empty-state message (product-owner-20260717T200000 Decision 3) ---
  const emptyStateEl = document.getElementById('empty-state-text-blog') as HTMLInputElement | null;
  if (emptyStateEl) {
    const seedEmptyStates = (
      window as unknown as { __editorSeed: { emptyStates: { projects: string; experience: string; blog: string; contact: string } } }
    ).__editorSeed.emptyStates;
    const workingEmptyStates = { ...seedEmptyStates };

    const emptyStatesAutosaver = makeAutosaver({
      save: () => saveArea('emptyStates', workingEmptyStates),
    });

    emptyStateEl.addEventListener('input', () => {
      workingEmptyStates.blog = emptyStateEl.value;
      emptyStatesAutosaver.markDirty();
    });

    emptyStateEl.addEventListener('blur', () => {
      void emptyStatesAutosaver.flush();
    });

    window.addEventListener('editor:save-all', () => {
      void emptyStatesAutosaver.flush();
    });
  }
</script>

<style>
  h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem;
  }

  .card-slot-wrap {
    position: relative;
  }

  .editor-note {
    max-width: 65ch;
    font-size: 0.85rem;
    color: var(--slate);
  }
</style>
