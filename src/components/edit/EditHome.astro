---
import Hero from '../Hero.astro';
import HeroGraphic from '../hero/HeroGraphic.astro';
import { HERO_VARIANTS, DEFAULT_HERO_VARIANT, type HeroVariant } from '../../lib/heroVariants';

// Homepage Highlights (tech-lead-20260720T113459Z / ui-ux-designer-
// 20260720T120500Z). A ref is NEVER a copied title — always `{type, ref}`,
// resolved against `projectsPool`/`blogPool` (loaded by the edit route at
// the SAME draft freshness as the public/preview resolution, KB-0020). The
// selection UI lives below the hero-graphic picker, in a bordered box
// matching its visual language (no new box style).
export type HighlightRef = { type: 'project' | 'blog'; ref: string };
export type HighlightsProjectPoolItem = {
  slug: string;
  title: string;
  category: string;
  startDate: string | null;
  endDate: string | null;
};
export type HighlightsBlogPoolItem = { id: string; title: string; date: string };

export type Props = {
  hero: {
    eyebrow: string;
    headlineHtml: string;
    lede: string;
    primaryCta: { label: string; href: string };
    ghostCta: { label: string; href: string };
    graphic?: HeroVariant;
  };
  highlights: HighlightRef[];
  projectsPool: HighlightsProjectPoolItem[];
  blogPool: HighlightsBlogPoolItem[];
  // NOTE (senior-frontend-dev-20260720): the edit route currently passes a
  // single `highlightsEmptyText` string (senior-backend-dev-20260720T114131Z
  // prop contract), NOT the full 5-field emptyStates record every other
  // Edit* component round-trips on save (EditContact/EditCollection/
  // EditBlogList all spread `{...seedEmptyStates}` and POST all 5 fields,
  // since `emptyStatesBodySchema` requires every key). A save built from
  // ONLY `highlights` would either fail validation (missing fields) or, if
  // defaulted, silently clobber the other four saved empty-state messages.
  // Accepting BOTH shapes here (full record preferred, string as a
  // fallback-only display value with save DISABLED) so this never crashes
  // or corrupts data before the route is aligned — see team board for the
  // one-line fix requested of senior-backend-dev.
  emptyStates?: { projects: string; experience: string; blog: string; contact: string; highlights: string };
  highlightsEmptyText?: string;
};

const { hero, highlights, projectsPool, blogPool, emptyStates, highlightsEmptyText } = Astro.props;
const resolvedEmptyStates = emptyStates ?? null;
const highlightsEmptyValue = resolvedEmptyStates?.highlights ?? highlightsEmptyText ?? '';
const currentGraphic: HeroVariant = hero.graphic ?? DEFAULT_HERO_VARIANT;
const HIGHLIGHTS_CAP = 6;

// Human labels for the picker buttons.
const GRAPHIC_LABELS: Record<HeroVariant, string> = {
  radar: 'Radar sweep',
  rotation: 'Rotation',
  synthesis: 'Synthesis',
  orbit: 'Orbit',
};
---

<div data-editable-area="home" data-current-graphic={currentGraphic}>
  <Hero
    eyebrow={hero.eyebrow}
    headlineHtml={hero.headlineHtml}
    lede={hero.lede}
    primaryCta={hero.primaryCta}
    ghostCta={hero.ghostCta}
    editable
  >
    <HeroGraphic slot="matrix" default={currentGraphic} />
  </Hero>

  <div class="graphic-picker" role="group" aria-label="Hero graphic">
    <div class="graphic-picker-head">
      <span class="graphic-picker-title mono">Hero graphic</span>
      <span class="graphic-picker-hint">Previewing a graphic won’t change your site — click <strong>Use this graphic</strong> to save it.</span>
    </div>
    <div class="graphic-picker-controls">
      <div class="graphic-picker-options">
        {HERO_VARIANTS.map((v) => (
          <button
            type="button"
            class="graphic-pick-btn mono"
            data-graphic-pick={v}
            aria-pressed={v === currentGraphic ? 'true' : 'false'}
          >{GRAPHIC_LABELS[v]}</button>
        ))}
      </div>
      <button type="button" class="graphic-confirm-btn" data-graphic-confirm disabled>
        Use this graphic
      </button>
    </div>
    <p class="graphic-picker-status mono" data-graphic-status aria-live="polite"></p>
  </div>

  <div class="graphic-picker highlights-picker" role="group" aria-label="Highlights">
    <div class="graphic-picker-head">
      <span class="graphic-picker-title mono">Highlights</span>
      <span class="graphic-picker-hint">Pick the projects and posts shown on the homepage, and the order they appear in (up to {HIGHLIGHTS_CAP}).</span>
    </div>

    <div class="highlights-section highlights-section-selected">
      <h3 class="highlights-subhead mono">Selected</h3>
      <div data-highlights-selected-groups></div>
      <p class="editor-note" data-highlights-empty-note hidden>Nothing selected yet — add from the pool below.</p>
    </div>

    <div class="highlights-section highlights-section-pool">
      <h3 class="highlights-subhead mono">Add more</h3>
      <p class="highlights-cap-note mono" data-highlights-cap-note hidden>Highlights is at its limit ({HIGHLIGHTS_CAP}) — remove one to add another.</p>
      <ul class="highlights-pool" data-highlights-pool></ul>
      <p class="editor-note" data-highlights-pool-empty hidden>Every project and post is already selected.</p>
    </div>

    <hr class="editor-divider" />
    <label class="editor-field-label mono" for="home-highlights-empty-state-text">Empty-state message</label>
    <input
      id="home-highlights-empty-state-text"
      class="editor-input"
      type="text"
      value={highlightsEmptyValue}
      readonly={resolvedEmptyStates === null}
      data-highlights-empty-savable={resolvedEmptyStates !== null ? 'true' : 'false'}
    />
    <p class="editor-note">Shown on the public homepage in place of the grid when zero highlights are selected.</p>
    {resolvedEmptyStates === null && (
      <p class="editor-note">
        Read-only for now — saving this message needs a small backend update (see team board). Your other
        empty-state messages are unaffected.
      </p>
    )}
  </div>

  <p class="editor-note">
    Page navigation and footer are not editable in this MVP
    (see product-owner-20260716T000000 on the team board).
  </p>
</div>

<script define:vars={{ seedHighlights: highlights, seedProjectsPool: projectsPool, seedBlogPool: blogPool, seedEmptyStates: resolvedEmptyStates }}>
  window.__editorSeed = window.__editorSeed || {};
  window.__editorSeed.highlights = seedHighlights;
  window.__editorSeed.projectsPool = seedProjectsPool;
  window.__editorSeed.blogPool = seedBlogPool;
  // null until the edit route passes the full 5-field emptyStates record —
  // see the Props comment above. The empty-state text field stays
  // read-only (no save wiring) while this is null, so partial data can
  // never clobber the other four saved empty-state messages.
  window.__editorSeed.emptyStates = seedEmptyStates;
</script>

<script>
  import { getPath, makeAutosaver, saveArea, sanitizeHeadlineHtml, setPath } from '../../lib/editor/client';
  import { commit, commitAtomic, register } from '../../lib/editor/history';
  import type {
    HighlightRef,
    HighlightsProjectPoolItem,
    HighlightsBlogPoolItem,
  } from './EditHome.astro';

  const AREA = 'home';
  const container = document.querySelector<HTMLElement>('[data-editable-area="home"]');

  const editorSeed = (
    window as unknown as {
      __editorSeed: {
        highlights: HighlightRef[];
        projectsPool: HighlightsProjectPoolItem[];
        blogPool: HighlightsBlogPoolItem[];
      };
    }
  ).__editorSeed;

  if (container) {
    const seed = {
      eyebrow: container.querySelector<HTMLElement>('[data-editable="eyebrow"]')?.textContent ?? '',
      headlineHtml: container.querySelector<HTMLElement>('[data-editable="headlineHtml"]')?.innerHTML ?? '',
      lede: container.querySelector<HTMLElement>('[data-editable="lede"]')?.textContent ?? '',
      primaryCta: {
        label: container.querySelector<HTMLElement>('[data-editable="primaryCta.label"]')?.textContent ?? '',
        href: container.querySelector<HTMLAnchorElement>('[data-editable="primaryCta.label"]')?.getAttribute('href') ?? '',
      },
      ghostCta: {
        label: container.querySelector<HTMLElement>('[data-editable="ghostCta.label"]')?.textContent ?? '',
        href: container.querySelector<HTMLAnchorElement>('[data-editable="ghostCta.label"]')?.getAttribute('href') ?? '',
      },
      // Confirmed graphic variant. Included in EVERY home save so a text
      // autosave never drops it — but only ever CHANGED by the explicit
      // "Use this graphic" confirm below, so merely previewing a variant
      // does not mutate this and does not trigger a save (no history bloat).
      graphic: container.getAttribute('data-current-graphic') ?? 'synthesis',
      // Ordered {type, ref} array (tech-lead-20260720T113459Z). Included in
      // EVERY home save alongside the hero fields — same "never drop the
      // other's field" discipline as `graphic` above — so a hero text
      // autosave never clobbers a highlights add/remove/move and vice
      // versa (they're one payload, one POST /api/content/home body).
      highlights: editorSeed.highlights,
    };

    const working: typeof seed = JSON.parse(JSON.stringify(seed));

    const autosaver = makeAutosaver({
      save: () => saveArea(AREA, working),
      snapshot: () => JSON.stringify(working),
    });

    // ---- Hero-graphic preview switcher + confirm-to-save ----
    // Previewing toggles which build-time-rendered variant is visible
    // (client-only, no network); confirming performs exactly ONE save of
    // the whole home area with the new `graphic` value.
    const GRAPHIC_VARIANTS = ['radar', 'rotation', 'synthesis', 'orbit'] as const;
    const canvas = container.querySelector<HTMLElement>('.hero-graphic-canvas');
    const pickBtns = Array.from(container.querySelectorAll<HTMLButtonElement>('[data-graphic-pick]'));
    const confirmBtn = container.querySelector<HTMLButtonElement>('[data-graphic-confirm]');
    const graphicStatus = container.querySelector<HTMLElement>('[data-graphic-status]');

    let previewGraphic = working.graphic;

    function showVariant(variant: string) {
      if (!canvas) return;
      for (const name of GRAPHIC_VARIANTS) {
        const el = canvas.querySelector<HTMLElement>(`[data-hero-variant="${name}"]`);
        if (el) el.hidden = name !== variant;
      }
    }

    function refreshPickerUi() {
      for (const btn of pickBtns) {
        btn.setAttribute('aria-pressed', String(btn.getAttribute('data-graphic-pick') === previewGraphic));
      }
      const changed = previewGraphic !== working.graphic;
      if (confirmBtn) confirmBtn.disabled = !changed;
      if (graphicStatus) {
        graphicStatus.textContent = changed
          ? 'Preview only — not saved yet.'
          : '';
      }
    }

    for (const btn of pickBtns) {
      btn.addEventListener('click', () => {
        const variant = btn.getAttribute('data-graphic-pick');
        if (!variant) return;
        previewGraphic = variant;
        showVariant(variant);
        refreshPickerUi();
      });
    }

    confirmBtn?.addEventListener('click', async () => {
      if (previewGraphic === working.graphic) return;
      working.graphic = previewGraphic;
      confirmBtn.disabled = true;
      if (graphicStatus) graphicStatus.textContent = 'Saving…';
      await autosaver.flush(); // exactly one save/commit for the confirmed change
      refreshPickerUi();
      if (graphicStatus) graphicStatus.textContent = 'Saved. This graphic is now on your live preview.';
    });

    function readEl(el: HTMLElement): string {
      return el.tagName === 'H1' ? sanitizeHeadlineHtml(el.innerHTML) : el.textContent ?? '';
    }

    function applyEl(el: HTMLElement, path: string, value: string) {
      if (el.tagName === 'H1') {
        el.innerHTML = value;
      } else {
        el.textContent = value;
      }
      setPath(working as unknown as Record<string, unknown>, path, value);
      void autosaver.flush(); // undo/redo apply — no following blur, must commit now
    }

    container.querySelectorAll<HTMLElement>('[data-editable]').forEach((el) => {
      // The CTA labels are real <a href> elements made contenteditable —
      // prevent a click from navigating away mid-edit.
      if (el.tagName === 'A') {
        el.addEventListener('click', (event) => event.preventDefault());
      }
      const path = el.getAttribute('data-editable');
      if (!path) return;
      const historyId = `home:${path}`;

      register({
        id: historyId,
        read: () => readEl(el),
        apply: (value) => applyEl(el, path, value),
      });

      el.addEventListener('input', () => {
        const value = readEl(el);
        setPath(working as unknown as Record<string, unknown>, path, value);
        autosaver.markDirty();
      });
      el.addEventListener('blur', () => {
        commit(historyId);
        void autosaver.flushIfDirty();
      });
    });

    container.querySelectorAll<HTMLButtonElement>('[data-editable-href]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const path = btn.getAttribute('data-editable-href');
        if (!path) return;
        const current = String(getPath(working, path) ?? '');
        const next = window.prompt('Edit URL', current);
        if (next === null) return;
        const value = next.trim();
        setPath(working as unknown as Record<string, unknown>, path, value);
        const anchor = btn.previousElementSibling as HTMLAnchorElement | null;
        if (anchor) anchor.setAttribute('href', value);
        void autosaver.flush(); // prompt confirm — discrete commit

        const historyId = `home:${path}`;
        register({
          id: historyId,
          read: () => String(getPath(working, path) ?? ''),
          apply: (v) => {
            setPath(working as unknown as Record<string, unknown>, path, v);
            const a = btn.previousElementSibling as HTMLAnchorElement | null;
            if (a) a.setAttribute('href', v);
            void autosaver.flush(); // undo/redo apply
          },
        });
        commitAtomic(historyId, current, value);
      });
    });

    // ---- Highlights selection (tech-lead-20260720T113459Z / ui-ux-
    // designer-20260720T120500Z) ----
    // Buttons only (no drag/checkbox, KB-0026) — every add/remove/move
    // click mutates `working.highlights` then flushes UNCONDITIONALLY
    // (discrete-commit site, like EditContact's link add/remove — NOT
    // routed through markDirty/flushIfDirty, since these are buttons, not
    // text fields). Titles are ALWAYS resolved from projectsPool/blogPool,
    // NEVER stored — the row is rebuilt via createElement/textContent only
    // (no innerHTML with pool-sourced text), so a title containing
    // HTML-like characters can never become a markup injection.
    const HIGHLIGHTS_CAP = 6;
    const projectsPool = editorSeed.projectsPool;
    const blogPool = editorSeed.blogPool;
    const selectedGroupsEl = container.querySelector<HTMLElement>('[data-highlights-selected-groups]');
    const selectedEmptyNoteEl = container.querySelector<HTMLElement>('[data-highlights-empty-note]');
    const poolListEl = container.querySelector<HTMLUListElement>('[data-highlights-pool]');
    const poolEmptyNoteEl = container.querySelector<HTMLElement>('[data-highlights-pool-empty]');
    const capNoteEl = container.querySelector<HTMLElement>('[data-highlights-cap-note]');

    function resolveHighlight(ref: HighlightRef): { title: string; typeLabel: string; metaLabel: string } | null {
      if (ref.type === 'project') {
        const p = projectsPool.find((item) => item.slug === ref.ref);
        return p ? { title: p.title, typeLabel: 'Project', metaLabel: p.category } : null;
      }
      const b = blogPool.find((item) => item.id === ref.ref);
      return b ? { title: b.title, typeLabel: 'Post', metaLabel: b.date } : null;
    }

    // Type-local grouping for KB-0020 cross-surface parity with the public
    // Highlights render (tech-lead-20260720T160424Z item 4 / ui-ux-designer-
    // 20260721T050000Z #8). Partitions `working.highlights` by `type` on
    // every render — stored flat-array order is unchanged; grouping is
    // display-only, same as the public page's partition. Lone-group
    // suppression: when only one type is present in the Selected list, no
    // nested <h4> — a flat list exactly like before grouping existed. An
    // empty type-group renders nothing (no heading, no placeholder).
    function typeIndices(type: HighlightRef['type']): number[] {
      const out: number[] = [];
      working.highlights.forEach((h, i) => {
        if (h.type === type) out.push(i);
      });
      return out;
    }

    function swapHighlights(a: number, b: number) {
      const tmp = working.highlights[a];
      working.highlights[a] = working.highlights[b];
      working.highlights[b] = tmp;
    }

    function buildSelectedGroup(
      groupHeading: string,
      entries: Array<{ ref: HighlightRef; index: number }>,
      showHeading: boolean
    ): HTMLDivElement {
      const wrap = document.createElement('div');
      wrap.className = 'highlights-group';
      if (showHeading) {
        const heading = document.createElement('h4');
        heading.className = 'mono group-subhead';
        heading.textContent = groupHeading;
        wrap.appendChild(heading);
      }
      const ol = document.createElement('ol');
      ol.className = 'highlights-list';
      ol.setAttribute('aria-label', `Selected ${groupHeading.toLowerCase()}, in display order`);
      entries.forEach((entry, posInGroup) => {
        ol.appendChild(buildSelectedRow(entry.ref, entry.index, posInGroup, entries.length));
      });
      wrap.appendChild(ol);
      return wrap;
    }

    function renderHighlights() {
      if (!selectedGroupsEl || !poolListEl) return;
      const total = working.highlights.length;
      const atCap = total >= HIGHLIGHTS_CAP;

      selectedGroupsEl.innerHTML = '';
      const projectEntries = working.highlights
        .map((ref, index) => ({ ref, index }))
        .filter((entry) => entry.ref.type === 'project');
      const blogEntries = working.highlights
        .map((ref, index) => ({ ref, index }))
        .filter((entry) => entry.ref.type === 'blog');
      const showGroupHeadings = projectEntries.length > 0 && blogEntries.length > 0;

      if (projectEntries.length > 0) {
        selectedGroupsEl.appendChild(buildSelectedGroup('Projects', projectEntries, showGroupHeadings));
      }
      if (blogEntries.length > 0) {
        selectedGroupsEl.appendChild(buildSelectedGroup('Blog', blogEntries, showGroupHeadings));
      }
      if (selectedEmptyNoteEl) selectedEmptyNoteEl.hidden = total > 0;
      if (capNoteEl) capNoteEl.hidden = !atCap;

      const selectedKeys = new Set(working.highlights.map((h) => `${h.type}:${h.ref}`));
      const availableProjects = projectsPool.filter((p) => !selectedKeys.has(`project:${p.slug}`));
      const availableBlog = blogPool.filter((b) => !selectedKeys.has(`blog:${b.id}`));

      poolListEl.innerHTML = '';
      for (const p of availableProjects) {
        poolListEl.appendChild(
          buildPoolRow({ type: 'project', ref: p.slug, title: p.title, metaLabel: `Project · ${p.category}` }, atCap)
        );
      }
      for (const b of availableBlog) {
        poolListEl.appendChild(
          buildPoolRow({ type: 'blog', ref: b.id, title: b.title, metaLabel: `Post · ${b.date}` }, atCap)
        );
      }
      if (poolEmptyNoteEl) poolEmptyNoteEl.hidden = availableProjects.length + availableBlog.length > 0;
    }

    function commitHighlights() {
      renderHighlights();
      void autosaver.flush(); // add/remove/move click — discrete commit, always saves
    }

    // `flatIndex` is the item's real position in `working.highlights` (used
    // for splice/swap — the array's stored authority). `posInGroup`/
    // `groupTotal` are the item's position WITHIN its type-group as
    // displayed — Move up/down boundaries and the position badge are keyed
    // off these, not the flat index, so moving reorders within the type
    // (type-local neighbor swap in the flat array) per ui-ux-designer-
    // 20260721T050000Z #8.
    function buildSelectedRow(ref: HighlightRef, flatIndex: number, posInGroup: number, groupTotal: number): HTMLLIElement {
      const li = document.createElement('li');
      li.className = 'highlights-row';

      const posSpan = document.createElement('span');
      posSpan.className = 'highlights-position mono';
      posSpan.textContent = `#${posInGroup + 1}`;
      li.appendChild(posSpan);

      const resolved = resolveHighlight(ref);

      if (!resolved) {
        const missing = document.createElement('span');
        missing.className = 'highlights-missing';
        missing.textContent = '(missing — this was deleted, remove it?)';
        li.appendChild(missing);

        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'card-remove-btn highlights-remove-btn';
        removeBtn.textContent = 'Remove';
        removeBtn.setAttribute('aria-label', 'Remove this missing highlight');
        removeBtn.addEventListener('click', () => {
          working.highlights.splice(flatIndex, 1);
          commitHighlights();
        });
        li.appendChild(removeBtn);
        return li;
      }

      const typeSpan = document.createElement('span');
      typeSpan.className = 'highlights-type mono';
      typeSpan.textContent = resolved.typeLabel;
      li.appendChild(typeSpan);

      const titleSpan = document.createElement('span');
      titleSpan.className = 'highlights-item-title';
      titleSpan.textContent = resolved.title;
      li.appendChild(titleSpan);

      const controls = document.createElement('span');
      controls.className = 'highlights-row-controls';

      // Move up/down grouped together, separated from the destructive
      // Remove control by a thin divider (ui-ux-designer-20260721T050000Z
      // #16) — same aria-labels/logic as before, layout-only change.
      const moveGroup = document.createElement('span');
      moveGroup.className = 'highlights-row-move-group';

      const upBtn = document.createElement('button');
      upBtn.type = 'button';
      upBtn.className = 'highlights-move-btn';
      upBtn.textContent = 'Move up';
      upBtn.setAttribute('aria-label', `Move ${resolved.title} up`);
      upBtn.disabled = posInGroup === 0;
      upBtn.addEventListener('click', () => {
        if (posInGroup === 0) return;
        const neighborIndex = typeIndices(ref.type)[posInGroup - 1];
        swapHighlights(flatIndex, neighborIndex);
        commitHighlights();
      });
      moveGroup.appendChild(upBtn);

      const downBtn = document.createElement('button');
      downBtn.type = 'button';
      downBtn.className = 'highlights-move-btn';
      downBtn.textContent = 'Move down';
      downBtn.setAttribute('aria-label', `Move ${resolved.title} down`);
      downBtn.disabled = posInGroup === groupTotal - 1;
      downBtn.addEventListener('click', () => {
        if (posInGroup === groupTotal - 1) return;
        const neighborIndex = typeIndices(ref.type)[posInGroup + 1];
        swapHighlights(flatIndex, neighborIndex);
        commitHighlights();
      });
      moveGroup.appendChild(downBtn);
      controls.appendChild(moveGroup);

      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'card-remove-btn highlights-remove-btn';
      removeBtn.textContent = 'Remove';
      removeBtn.setAttribute('aria-label', `Remove ${resolved.title}`);
      removeBtn.addEventListener('click', () => {
        working.highlights.splice(flatIndex, 1);
        commitHighlights();
      });
      controls.appendChild(removeBtn);

      li.appendChild(controls);
      return li;
    }

    function buildPoolRow(
      item: { type: HighlightRef['type']; ref: string; title: string; metaLabel: string },
      atCap: boolean
    ): HTMLLIElement {
      const li = document.createElement('li');
      li.className = 'highlights-pool-row';

      const info = document.createElement('span');
      info.className = 'highlights-pool-info';
      const titleSpan = document.createElement('span');
      titleSpan.className = 'highlights-pool-title';
      titleSpan.textContent = item.title;
      const metaSpan = document.createElement('span');
      metaSpan.className = 'highlights-pool-meta mono';
      metaSpan.textContent = item.metaLabel;
      info.append(titleSpan, metaSpan);
      li.appendChild(info);

      const addBtn = document.createElement('button');
      addBtn.type = 'button';
      addBtn.className = 'editor-add-btn highlights-add-btn';
      addBtn.textContent = '+ Add';
      addBtn.disabled = atCap;
      addBtn.setAttribute('aria-label', `Add ${item.title} to Highlights`);
      addBtn.addEventListener('click', () => {
        if (working.highlights.length >= HIGHLIGHTS_CAP) return;
        working.highlights.push({ type: item.type, ref: item.ref });
        commitHighlights();
      });
      li.appendChild(addBtn);
      return li;
    }

    renderHighlights();

    window.addEventListener('editor:save-all', () => {
      void autosaver.flush();
    });
  }

  // ---- Highlights empty-state message (product-owner-20260717T200000
  // Decision 3 pattern, extended by tech-lead-20260720T113459Z to a 5th
  // `highlights` key on the shared emptyStatesBodySchema) ----
  // Only wired up to autosave when the route supplied the FULL 5-field
  // record (see the Props/define:vars comments above) — every OTHER
  // emptyStates-writing editor round-trips all 5 fields on every save
  // (emptyStatesBodySchema requires them all), so saving from a partial
  // object here would either 400 (validation_failed) or, if defaulted,
  // silently wipe the other four saved empty-state messages. The field
  // itself stays visible (read-only) either way so the current value is
  // never hidden from Isaiah.
  const highlightsEmptyStateEl = document.getElementById('home-highlights-empty-state-text') as HTMLInputElement | null;
  const seedEmptyStates = (
    window as unknown as {
      __editorSeed: {
        emptyStates: { projects: string; experience: string; blog: string; contact: string; highlights: string } | null;
      };
    }
  ).__editorSeed?.emptyStates ?? null;

  if (highlightsEmptyStateEl && seedEmptyStates) {
    const workingEmptyStates = { ...seedEmptyStates };

    const emptyStatesAutosaver = makeAutosaver({
      save: () => saveArea('emptyStates', workingEmptyStates),
      snapshot: () => JSON.stringify(workingEmptyStates),
    });

    highlightsEmptyStateEl.addEventListener('input', () => {
      workingEmptyStates.highlights = highlightsEmptyStateEl.value;
      emptyStatesAutosaver.markDirty();
    });

    highlightsEmptyStateEl.addEventListener('blur', () => {
      void emptyStatesAutosaver.flushIfDirty();
    });

    window.addEventListener('editor:save-all', () => {
      void emptyStatesAutosaver.flush();
    });
  }
</script>

