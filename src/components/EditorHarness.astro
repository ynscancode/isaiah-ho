---
// The one client island for the whole /edit surface (tech-lead-20260715T192159
// frontend contract, section 5). Renders the fixed save/preview/publish/logout
// toolbar and owns the styling for every editor-only affordance added to
// Hero.astro / Card.astro (edit-link buttons, remove buttons, contenteditable
// outlines) via :global() selectors — kept OUT of those shared components'
// own <style> blocks on purpose so public pages' compiled CSS never grows a
// single byte from this feature. This component is only ever imported by
// src/pages/edit/[...path].astro (prerender=false, session-gated).

export type Props = {
  contentSource?: 'draft' | 'master' | 'build';
};

const { contentSource } = Astro.props;
---

<div id="editor-toolbar" class="editor-toolbar" role="region" aria-label="Content editor controls">
  {contentSource === 'build' && (
    <p id="editor-readonly-banner" class="editor-toolbar-banner" role="alert">
      Can't reach GitHub — showing the last published content. Editing is disabled.
    </p>
  )}
  <div id="editor-conflict-banner" class="editor-toolbar-banner" role="alert" hidden>
    Preview is out of sync with the site code — publish or ask for help.
  </div>
  <div class="editor-toolbar-status">
    <strong>Editing draft</strong>
    <span id="editor-status-text" data-status="idle">No changes</span>
  </div>
  <div class="editor-toolbar-actions">
    <button type="button" id="editor-save-btn" class="editor-btn editor-btn-primary" disabled={contentSource === 'build'}>Save to draft</button>
    <button type="button" id="editor-undo-btn" class="editor-btn" disabled>Undo</button>
    <button type="button" id="editor-redo-btn" class="editor-btn" disabled>Redo</button>
    <button type="button" id="editor-preview-btn" class="editor-btn">Preview</button>
    <a href="/edit/history" id="editor-history-btn" class="editor-btn">History</a>
    <button type="button" id="editor-publish-btn" class="editor-btn editor-btn-publish">Publish</button>
    <button type="button" id="editor-logout-btn" class="editor-btn editor-btn-ghost">Log out</button>
  </div>
  <div id="editor-message" class="editor-toolbar-message" role="status" aria-live="polite"></div>
</div>

<style is:global>
  /* Reserve room so the fixed toolbar never covers the footer's content;
     applied only on /edit pages since this stylesheet is only ever bundled
     there. */
  body:has(#editor-toolbar) {
    padding-bottom: 5.5rem;
  }

  .editor-toolbar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 500;
    background: var(--ink, #12182b);
    color: var(--paper, #f5f3ee);
    border-top: 1px solid #3a4468;
    padding: 0.85rem 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.5rem;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.85rem;
  }

  .editor-toolbar-status {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }

  .editor-toolbar-status strong {
    font-size: 0.8rem;
  }

  #editor-status-text[data-status="dirty"] {
    color: #f0c987;
  }
  #editor-status-text[data-status="saving"] {
    color: #c9ccd9;
  }
  #editor-status-text[data-status="saved"] {
    color: #7fd6a0;
  }
  #editor-status-text[data-status="retrying"] {
    /* Transient upstream blip (Design A3) — same "still pending, not lost"
       family as dirty/saving, deliberately NOT the red error color so it
       reads as accurate rather than alarming. */
    color: #f0c987;
  }
  #editor-status-text[data-status="error"] {
    color: #ff9c9c;
  }

  .editor-toolbar-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .editor-btn {
    font-family: inherit;
    font-size: 0.82rem;
    padding: 0.5rem 0.9rem;
    border-radius: 2px;
    border: 1px solid #5f6990;
    background: transparent;
    color: var(--paper, #f5f3ee);
    cursor: pointer;
    /* .editor-btn is also used on the History <a> (ui-ux-designer-
       20260719T010000 point 2) — Nav.astro's own `a { text-decoration:
       none }` is scoped and does NOT cascade into this global stylesheet,
       so set it explicitly here rather than relying on any button default. */
    text-decoration: none;
    display: inline-block;
  }

  .editor-btn:hover {
    border-color: var(--signal, #c87f0a);
  }

  .editor-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    border-color: #5f6990;
  }
  .editor-btn:disabled:hover {
    border-color: #5f6990;
  }

  .editor-btn-primary {
    background: var(--signal, #c87f0a);
    color: var(--ink, #12182b);
    border-color: var(--signal, #c87f0a);
    font-weight: 600;
  }

  .editor-btn-publish {
    border-color: #7fd6a0;
    color: #7fd6a0;
  }

  .editor-btn-ghost {
    opacity: 0.8;
  }

  .editor-toolbar-message {
    flex-basis: 100%;
    font-size: 0.78rem;
    color: #c9ccd9;
  }

  .editor-toolbar-message a {
    color: var(--signal, #c87f0a);
  }

  .editor-toolbar-banner {
    flex-basis: 100%;
    margin: 0;
    padding: 0.5rem 0.75rem;
    border-radius: 2px;
    font-size: 0.8rem;
    background: rgba(200, 127, 10, 0.18);
    border: 1px solid var(--signal, #c87f0a);
    color: var(--paper, #f5f3ee);
  }

  #editor-readonly-banner {
    background: rgba(192, 57, 43, 0.18);
    border-color: #ff9c9c;
  }

  /* Set on <html> when contentSource === 'build' (see script below) so
     editor-only affordances in Hero.astro / Card.astro can also style
     themselves as read-only if needed — a UX affordance only, not the
     trust boundary (KB-0017); the server guard is the real protection. */
  html[data-editor-readonly="true"] [contenteditable="true"] {
    pointer-events: none;
    opacity: 0.7;
  }

  /* --- Editor-only affordances rendered inside Hero.astro / Card.astro --- */

  [contenteditable="true"] {
    outline: 1px dashed #8891ab;
    outline-offset: 2px;
    border-radius: 2px;
  }

  [contenteditable="true"]:focus {
    outline: 2px solid var(--signal, #c87f0a);
  }

  /* Bug 1 (senior-frontend-dev-20260721, tech-lead leading hypothesis,
     confirm in-browser via TEAM-BOARD repro): the category eyebrow
     (Card.astro `.card-eyebrow`) is the ONLY inline `<span
     contenteditable>` in this editor — title/body/detail are block
     elements. An EMPTY inline contenteditable has no anchorable caret box
     in Chromium, so a category left empty (e.g. right after "+ Add", which
     auto-focuses it) silently drops keystrokes. Giving it a block-ish inline
     box even while empty lets the browser place/keep a caret in it. */
  .card-eyebrow[contenteditable="true"] {
    display: inline-block;
    min-width: 1ch;
    min-height: 1em;
  }

  /* Placeholder-not-prefilled hint (product-owner-20260717T200000 Decision 4
     / ui-ux-designer-20260717T210000 section 6) — new entries seed truly
     empty contenteditable fields; this shows greyed hint text via CSS only,
     never mixed into the real saved value. */
  [contenteditable="true"]:empty::before {
    content: attr(data-placeholder);
    color: var(--slate, #5b6472);
    opacity: 0.65;
    font-style: italic;
    pointer-events: none;
  }

  .card-date-input {
    max-width: 11rem;
  }

  .editor-divider {
    border: none;
    border-top: 1px solid var(--line, #d8d3c7);
    margin: 2rem 0 1.5rem;
  }

  .cta-edit-group {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .edit-href-btn {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: transparent;
    border: 1px solid currentColor;
    color: inherit;
    opacity: 0.75;
    padding: 0.2rem 0.45rem;
    border-radius: 2px;
    cursor: pointer;
  }

  .edit-href-btn:hover {
    opacity: 1;
  }

  .card-remove-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: #fdfcfa;
    border: 1px solid #c0392b;
    color: #c0392b;
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    cursor: pointer;
  }

  /* EditHome.astro's Highlights rows build their Remove buttons via
     document.createElement with class="card-remove-btn highlights-remove-btn"
     to reuse .card-remove-btn's red/mono visual styling without duplicating
     it — but they need position:static instead of .card-remove-btn's
     absolute top-right placement, since a .highlights-row list item is
     never position:relative the way Card.astro's own wrapper is. EditHome's
     OWN <style> block cannot supply that override: it's scoped CSS, and
     Astro only stamps the data-astro-cid scoping attribute onto markup its
     compiler emits, never onto elements created at runtime via
     createElement — so a scoped `.highlights-remove-btn { position: static }`
     silently never matches these buttons, and .card-remove-btn's absolute
     positioning wins, floating the button to the top-right corner of the
     whole page (senior-frontend-dev-20260721 investigation). This override
     lives here instead, in the one stylesheet that's genuinely global
     (is:global, same reason .card-remove-btn itself lives here), so it
     actually reaches the dynamically-created button; same specificity as
     .card-remove-btn (one class each), so source order — this rule after
     .card-remove-btn — is what makes it win. */
  .highlights-remove-btn {
    position: static;
  }

  .card-href-field {
    margin: 0.8rem 0 0;
    font-size: 0.68rem;
    color: var(--slate, #5b6472);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .editor-add-btn {
    margin-top: 1.5rem;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.9rem;
    padding: 0.7rem 1.2rem;
    border: 1px dashed var(--slate, #5b6472);
    border-radius: 4px;
    background: transparent;
    color: inherit;
    cursor: pointer;
  }

  .editor-add-btn:hover {
    border-color: var(--signal, #c87f0a);
    color: var(--signal-text, #8a5a00);
  }

  .editor-field-label {
    display: block;
    margin: 1.5rem 0 0.4rem;
  }

  .editor-input {
    font-family: inherit;
    font-size: 1rem;
    width: 100%;
    max-width: 40rem;
    padding: 0.5rem 0.7rem;
    border: 1px solid var(--line, #d8d3c7);
    border-radius: 2px;
    background: #fff;
    color: var(--ink, #12182b);
  }

  .editor-textarea {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.9rem;
    line-height: 1.5;
    white-space: pre-wrap;
    width: 100%;
    max-width: 70ch;
    min-height: 16rem;
    padding: 1rem;
    border: 1px solid var(--line, #d8d3c7);
    border-radius: 4px;
    background: #fdfcfa;
    color: var(--ink, #12182b);
  }

  select.editor-input {
    color: var(--ink, #12182b);
    background: #fff;
  }

  .editor-inline-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin: 0.4rem 0 0;
  }
</style>

<script>
  import {
    fetchPreview,
    logoutAndRedirect,
    pollPreviewStatus,
    publishDraft,
  } from '../lib/editor/client';
  import { canRedo, canUndo, commitActive, redo, undo } from '../lib/editor/history';

  const statusText = document.getElementById('editor-status-text');
  const message = document.getElementById('editor-message');
  const saveBtn = document.getElementById('editor-save-btn') as HTMLButtonElement | null;
  const undoBtn = document.getElementById('editor-undo-btn') as HTMLButtonElement | null;
  const redoBtn = document.getElementById('editor-redo-btn') as HTMLButtonElement | null;
  const previewBtn = document.getElementById('editor-preview-btn');
  const publishBtn = document.getElementById('editor-publish-btn');
  const logoutBtn = document.getElementById('editor-logout-btn');
  const conflictBanner = document.getElementById('editor-conflict-banner');

  // --- Item 5: undo/redo toolbar controls ---
  // Item 5 design (tech-lead-20260718T082028 / ui-ux-designer-20260718T103000):
  // buttons stay disabled until the shared history singleton reports a
  // non-empty stack; undo()/redo() themselves route field application
  // through the SAME makeAutosaver path each field already uses, so save
  // failures/stale_form surface exactly like a manual edit (no parallel UI
  // needed here).
  function syncHistoryButtons() {
    if (undoBtn) undoBtn.disabled = !canUndo();
    if (redoBtn) redoBtn.disabled = !canRedo();
  }
  syncHistoryButtons();
  window.addEventListener('editor:history-changed', syncHistoryButtons);

  // Bug 2a: commit whatever field is currently focused (if it actually
  // changed) BEFORE undo()/redo() reads the stack — the mousedown guard
  // above stops these buttons from stealing focus/blurring the field, so
  // without this a just-typed, not-yet-committed edit would be skipped by
  // undo() (which pops an older step instead) and NOT flushed to git (no
  // per-step save is added here — commitActive() only pushes an in-memory
  // history step, same as a normal blur would have).
  undoBtn?.addEventListener('click', () => {
    commitActive();
    undo();
  });
  redoBtn?.addEventListener('click', () => {
    commitActive();
    redo();
  });

  // Nice-to-have keyboard shortcuts (ui-ux-designer-20260718T103000): only
  // fire when focus is OUTSIDE an input/textarea/contenteditable, so the
  // browser's native in-field keystroke undo is never shadowed.
  window.addEventListener('keydown', (event) => {
    if (!(event.ctrlKey || event.metaKey) || event.key.toLowerCase() !== 'z') return;
    const active = document.activeElement;
    const tag = active?.tagName;
    const isEditable =
      tag === 'INPUT' ||
      tag === 'TEXTAREA' ||
      (active instanceof HTMLElement && active.isContentEditable);
    if (isEditable) return;
    event.preventDefault();
    if (event.shiftKey) {
      redo();
    } else {
      undo();
    }
  });

  function setMessage(text: string) {
    if (message) message.textContent = text;
  }

  // contentSource === 'build' read-only affordance (UX only — KB-0017; the
  // server guard is the real trust boundary). #editor-readonly-banner's
  // presence in the DOM is the server-rendered signal; mirror it onto
  // <html> so any editor-only affordance elsewhere can key off it too.
  if (document.getElementById('editor-readonly-banner')) {
    document.documentElement.dataset.editorReadonly = 'true';
    if (saveBtn) saveBtn.disabled = true;
  }

  // RC1 draft-sync conflict banner (tech-lead-20260717T090321 Decision 1 /
  // senior-backend-dev-20260717T180600): ensureDraft() (called from
  // saveArea() in every view's first save of the session) dispatches this
  // once it knows the server's syncState. Never auto-resolved — the user
  // has to publish or get help.
  window.addEventListener('editor:draft-sync-state', (event) => {
    const detail = (event as CustomEvent<{ syncState: string }>).detail;
    if (!conflictBanner || !detail) return;
    if (detail.syncState === 'conflict') {
      conflictBanner.removeAttribute('hidden');
    } else {
      conflictBanner.setAttribute('hidden', '');
    }
  });

  // Views (EditHome/EditAbout/etc.) update this element's data-status /
  // textContent directly and listen for `editor:save-all`.
  saveBtn?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('editor:save-all'));
  });

  // --- Item B: preview build freshness/timing (tech-lead-20260720T051536) ---
  // Bounded client-side poll of the JUST-TRIGGERED build's own readiness,
  // correlated by targetSha — this is the actual fix: the reveal only
  // happens once that specific build is READY, never the moving alias.
  // Interval is always cleared on READY/ERROR/timeout, and any new Preview
  // click stops a still-running poll before starting a fresh one — no
  // unbounded timers survive a re-click or accumulate.
  const PREVIEW_POLL_INTERVAL_MS = 3500;
  const PREVIEW_POLL_MAX_ATTEMPTS = 26; // ~91s ceiling at the interval above

  let previewPollTimer: ReturnType<typeof setInterval> | undefined;

  function stopPreviewPoll() {
    if (previewPollTimer) {
      clearInterval(previewPollTimer);
      previewPollTimer = undefined;
    }
  }

  function appendPreviewLink(url: string, label: string, caveat?: string) {
    if (!message) return;
    const link = document.createElement('a');
    link.href = url;
    link.target = '_blank';
    link.rel = 'noopener noreferrer';
    link.textContent = label;
    message.appendChild(link);
    if (caveat) message.append(` ${caveat}`);
  }

  previewBtn?.addEventListener('click', async () => {
    stopPreviewPoll();
    setMessage('Building preview… this takes about 30s.');
    const result = await fetchPreview();
    if (!result) {
      setMessage('No draft yet — save a change first, then try Preview again.');
      return;
    }

    // Non-blocking honest note when the draft couldn't be synced with the
    // latest published site — never swallowed, never blocks the rest of
    // the flow.
    const conflictNote =
      result.syncState === 'conflict'
        ? " Note: couldn't merge the latest published site changes into this preview."
        : '';
    function setPreviewMessage(text: string) {
      setMessage(text + conflictNote);
    }

    if (!result.pollable) {
      // Graceful degradation (no Vercel API token/project configured
      // server-side): today's behavior — show the alias link immediately
      // with an honest caveat, rather than pretending we can confirm
      // readiness.
      setPreviewMessage(
        'Preview is building (~30s). The link below may briefly show a previous build until the new one finishes: '
      );
      appendPreviewLink(result.previewUrl, `Open preview: ${result.previewUrl}`);
      return;
    }

    setPreviewMessage('Building preview… this takes about 30s.');
    let attempts = 0;
    previewPollTimer = setInterval(async () => {
      attempts++;
      const status = await pollPreviewStatus(result.targetSha);

      if (status?.pollable && status.state === 'READY' && status.url) {
        stopPreviewPoll();
        setPreviewMessage('Preview is ready: ');
        appendPreviewLink(status.url, `Open preview: ${status.url}`);
        return;
      }

      if (status?.pollable && status.state === 'ERROR') {
        stopPreviewPoll();
        setPreviewMessage(
          'Preview build failed. You can try Preview again, or open the last known build: '
        );
        appendPreviewLink(result.previewUrl, `Open preview: ${result.previewUrl}`, '(may show a previous build)');
        return;
      }

      if (status?.pollable && (status.state === 'QUEUED' || status.state === 'BUILDING')) {
        setPreviewMessage(
          `Building preview… ${status.state === 'QUEUED' ? 'queued' : 'still building'} (~30s).`
        );
      }
      // A null/non-pollable poll result (transient fetch failure, or the
      // server briefly can't see the deployment yet) is not an error —
      // just keep polling until READY/ERROR/timeout below.

      if (attempts >= PREVIEW_POLL_MAX_ATTEMPTS) {
        stopPreviewPoll();
        setPreviewMessage(
          'Still building — taking longer than expected. Open when ready (may show a previous build until it finishes): '
        );
        appendPreviewLink(result.previewUrl, `Open preview: ${result.previewUrl}`, '(may show a previous build)');
      }
    }, PREVIEW_POLL_INTERVAL_MS);
  });

  publishBtn?.addEventListener('click', async () => {
    if (!window.confirm('Publish the current draft to the live site?')) return;
    setMessage('Publishing…');
    const result = await publishDraft();
    if (result.conflict) {
      setMessage('Publish failed: the draft has a merge conflict with master and needs manual resolution.');
      return;
    }
    if (!result.ok) {
      setMessage('Publish failed. Check the network tab / server logs.');
      return;
    }
    setMessage('Published. The live site will update shortly once the deploy finishes.');
  });

  logoutBtn?.addEventListener('click', () => {
    void logoutAndRedirect();
  });

  // Global rollup: every view's script dispatches `editor:area-status` so the
  // toolbar can show the worst-case status across all areas on the page
  // (in practice there is exactly one editable area per /edit/* route).
  window.addEventListener('editor:area-status', (event) => {
    const detail = (event as CustomEvent<{ status: string; label: string }>).detail;
    if (!statusText || !detail) return;
    statusText.textContent = detail.label;
    statusText.dataset.status = detail.status;
  });

  // Fired by src/lib/editor/client.ts whenever a mutating /api/** call
  // (save, ensure-draft, delete, publish, logout) gets back the server's
  // CSRF-invalid contract (403, { error: "csrf_invalid", action: "reauth" }
  // — see senior-backend-dev-20260717T010600). Distinct from a generic
  // save failure: the fix isn't "try again", it's "log in again". Replaces
  // whatever the toolbar message currently shows with a clear explanation
  // and a real recovery link back into the editor post-login.
  window.addEventListener('editor:reauth-needed', () => {
    if (statusText) {
      statusText.textContent = 'Session expired';
      statusText.dataset.status = 'error';
    }
    if (message) {
      message.textContent = '';
      message.append('Your session expired — log in again to keep editing. ');
      const link = document.createElement('a');
      link.href = '/api/auth/login?redirect_to=/edit';
      link.textContent = 'Log in again';
      message.appendChild(link);
    }
  });

  // Fired by makeAutosaver() (src/lib/editor/client.ts) whenever a save gets
  // back the server's stale_form contract (409 — RC3 baseImage guard, see
  // senior-backend-dev-20260717T180600 / tech-lead-20260718T041814 D3): the
  // page's view of the draft is out of date and a background save was
  // rejected rather than risking clobbering a newer draft. NEVER auto-reload
  // here — that would silently drop whatever the user has typed since; the
  // user has to click through, same as the reauth affordance above.
  window.addEventListener('editor:stale-form', () => {
    if (statusText) {
      statusText.textContent = 'Save failed';
      statusText.dataset.status = 'error';
    }
    if (message) {
      message.textContent = '';
      message.append('Content changed on the server — reload to continue. ');
      const link = document.createElement('a');
      link.href = '#';
      link.textContent = 'Reload';
      link.addEventListener('click', (event) => {
        event.preventDefault();
        location.reload();
      });
      message.appendChild(link);
    }
  });
</script>
