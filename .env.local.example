# Copy to .env.local for local dev (gitignored — .env* is already in .gitignore).
# NEVER commit real values. All of these are server-only secrets or config;
# none are PUBLIC_-prefixed except PUBLIC_SITE_URL (which is not secret).

# --- GitHub OAuth App (owner login gate) ---
# Create at https://github.com/settings/developers — a regular OAuth App
# (not a fine-grained PAT). Authorization callback URL must be
# {PUBLIC_SITE_URL}/api/auth/callback.
GITHUB_OAUTH_CLIENT_ID=placeholder-client-id
GITHUB_OAUTH_CLIENT_SECRET=placeholder-client-secret

# The only GitHub username allowed to obtain an editor session. Compared
# constant-time against the OAuth-resolved login on every callback.
ADMIN_GITHUB_USERNAME=ynscancode

# Random, high-entropy secret used to HMAC-sign the session cookie, the
# oauth_state CSRF cookie, and the double-submit CSRF token. Rotate to
# invalidate all sessions. Generate with e.g. `openssl rand -base64 32`.
SESSION_SECRET=placeholder-session-secret-generate-a-real-one

# Canonical site origin (no trailing slash), used to build the OAuth
# redirect_uri and to validate/construct absolute URLs server-side.
PUBLIC_SITE_URL=http://localhost:4321

# --- Git-write path (draft branch commits + publish) ---
# Fine-grained GitHub PAT scoped to exactly one repo, Contents: Read & Write
# only. MVP token strategy per tech-lead architecture spec (GitHub App
# installation token is the longer-term upgrade path, not required for MVP).
GIT_WRITE_TOKEN=placeholder-fine-grained-pat

# "owner/repo" — the single repo the git-write API is allowed to touch.
GITHUB_REPO=ynscancode/isaiah-ho

# Branch the editor commits to; publish merges this branch into master.
DRAFT_BRANCH=editor-draft

# Optional. Template for the draft branch's live preview URL, with a
# `{branch}` placeholder substituted at request time (e.g.
# "https://isaiah-ho-git-{branch}-<your-vercel-scope>.vercel.app"). If unset,
# falls back to a GitHub branch URL so responses are never broken — but the
# frontend editor UI wants a real Vercel preview link, so devops-engineer
# should set this once the Vercel project's branch-deploy URL pattern is known.
VERCEL_PREVIEW_URL_TEMPLATE=
